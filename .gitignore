# ============================================================
# MEMBEGO — .gitignore
# ============================================================

# --- Entorno y secretos (NUNCA subir) ---
.env.sentry-build-plugin
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# --- Base de datos local (SQLite) ---
db/
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# --- Next.js ---
/.next/
/out/
/build

# --- Dependencias ---
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Logs del sistema ---
*.log
dev.log
dev.out.log
server.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Archivos del sistema operativo ---
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Herramientas de desarrollo ---
.vercel
.claude
.z-ai-config
local-*

# --- Archivos internos del proyecto (no son código) ---
worklog.md
agent-ctx/
tool-results/
download/

# --- Pruebas ---
/coverage
test/
prompt/

# --- Certificados ---
*.pem

# --- Bun ---
bun.lockb

# --- Scripts internos de Z.ai ---
.zscripts/
mini-services/
skills/
examples/
