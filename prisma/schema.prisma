generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AppRole {
  SUPERADMIN
  ADMIN_EMPRESA // legacy: admin de empresa (se mantiene por usuarios existentes)
  EMPLEADO
  CLIENTE
  // Roles de equipo de empresa (deben coincidir con AppRole en src/types).
  ADMINISTRADOR
  GERENTE
  CAJERO
  RECEPCION
  MARKETING // difusión: promociones, campañas, publicaciones, audiencia, notificaciones
  SUPERVISOR // operación: dashboard/reportes, clientes, validar pagos, scanner
}

enum NotifTipo {
  PAGO_APROBADO
  PAGO_RECHAZADO
  NUEVO_COMPROBANTE
  MEMBRESIA_POR_VENCER
  MEMBRESIA_ACTIVADA
  PROMOCION_NUEVA
  RECOMPENSA_REFERIDO
  SISTEMA
  TICKET_NUEVO
  TICKET_RESPUESTA
  TICKET_ACTUALIZADO
}

enum TicketEstado {
  NUEVO
  EN_PROCESO
  ESPERANDO_CLIENTE
  RESUELTO
  CERRADO
}

enum TicketCategoria {
  PAGO
  MEMBRESIA
  BENEFICIOS
  APP
  OTRO
}

enum TicketAutor {
  CLIENTE
  ADMIN
  SISTEMA
}

enum MembershipEstado {
  PENDIENTE // solicitada, sin pago
  PENDIENTE_PAGO // comprobante enviado, esperando validación
  RECHAZADA // pago rechazado por admin
  ACTIVA
  VENCIDA
  CANCELADA
}

enum MetodoPagoTipo {
  TRANSFERENCIA
  PRESENCIAL
}

enum InvitacionEstado {
  PENDIENTE
  ACEPTADA
  CANCELADA
  EXPIRADA
}

enum AuditAccion {
  VISITA_CONFIRMADA
  PAGO_APROBADO
  PAGO_RECHAZADO
  MEMBRESIA_CANCELADA
  MEMBRESIA_RENOVADA
  QR_GENERADO
  QR_USADO
  QR_COMPARTIDO
  COMPROBANTE_IMPRESO
  REFERIDO_COMPLETADO
  RECOMPENSA_OTORGADA
  NOTA_INTERNA
  PLANTILLA_RECIBO_ACTUALIZADA
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  supabaseId         String    @unique
  email              String    @unique
  name               String
  role               AppRole   @default(CLIENTE)
  companyId          String?
  company            Company?  @relation(fields: [companyId], references: [id])
  // Consentimiento (cumplimiento): rastro auditable de aceptación de términos
  // y opt-in de comunicaciones de marketing, con la versión y el momento.
  termsAcceptedAt    DateTime?
  termsVersion       String?
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  memberships     Membership[]
  visits          Visit[]             @relation("EmpleadoVisits")
  auditLogs       AuditLog[]
  comprobantes    Comprobante[]
  notificaciones  Notificacion[]
  follows         CompanyFollow[]
  promosGuardadas PromocionGuardada[]
  notasCliente    ClienteNota[]
  intereses       UserInteres[]
  empresasAcceso  UserCompanyAccess[]

  // Listados de empleados por empresa (/admin/empleados) y conteos por empresa.
  transaccionesComoEmpleado Transaction[]              @relation("TransactionEmpleado")
  transicionesTransaccion   TransactionTransicion[]
  impresionesRecibo         ReceiptImpresion[]
  comprasAprobadas          ProductoCompra[]           @relation("CompraAprobadaPor")
  transicionesCompra        ProductoCompraTransicion[]

  @@index([companyId])
  @@map("users")
}

/// Acceso multi-empresa para usuarios de staff: un mismo administrador puede
/// gestionar VARIAS empresas. `User.companyId` sigue siendo la empresa ACTIVA
/// (la que ve en su panel); esta tabla define a cuáles puede cambiar.
model UserCompanyAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("user_company_access")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        String // "carwash" | "restaurante"
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  email     String?
  telefono  String?
  direccion String?
  ciudad    String?
  categoria String?
  website   String?

  // FASE 2: Marketplace fields
  isPublished           Boolean  @default(true)
  isFeatured            Boolean  @default(false)
  featuredOrder         Int?
  bannerUrl             String?
  galleryImages         String[] @default([])
  provincia             String?
  pais                  String?
  // F5/Onboarding: datos legales y de ubicación precisa (paso 2-3 del wizard).
  razonSocial           String?
  codigoPostal          String?
  latitud               Float?
  longitud              Float?
  zonaCobertura         String? // texto libre: barrios/zonas atendidas o radio
  // F5/Onboarding paso 4: configuración regional y de marca. Preferencia por
  // empresa aplicada al FORMATEAR (moneda/fecha); no traduce la UI ni convierte
  // divisas (Decisión 4 del plan de onboarding).
  moneda                String   @default("DOP") // ISO 4217: DOP, USD, EUR…
  zonaHoraria           String   @default("America/Santo_Domingo") // IANA
  idioma                String   @default("es-DO") // locale BCP 47
  // Fase E7: método de escaneo predeterminado del escáner ("camara" | "lector").
  // El operador puede cambiarlo en pantalla sin recargar; esto es solo el valor
  // inicial que la empresa configura.
  escanerModo           String   @default("camara")
  colorPrimario         String? // hex de marca, ej. "#0ea5e9"
  politicaCancelacion   String?
  politicaPrivacidad    String?
  terminosEmpresa       String?
  whatsapp              String?
  instagram             String?
  facebook              String?
  tiktok                String?
  googleMapsUrl         String?
  // F4.1: horario de atención mostrado en el perfil público (texto libre,
  // ej. "Lun-Vie 8:00-18:00 · Sáb 9:00-14:00").
  horario               String?
  totalMembersCount     Int      @default(0)
  activePromotionsCount Int      @default(0)
  averageRating         Decimal? @db.Decimal(3, 2)

  // O-13: beneficio de bienvenida financiado por la EMPRESA (opt-in). Se
  // aplica UNA sola vez, en la primera activación de membresía del cliente
  // en esta empresa. PORCENTAJE = % sobre el precio del plan; MONTO = importe
  // fijo (nunca supera el precio del plan).
  bienvenidaActiva Boolean  @default(false)
  bienvenidaTipo   String   @default("PORCENTAJE") // PORCENTAJE | MONTO
  bienvenidaValor  Decimal? @db.Decimal(10, 2)

  users                  User[]
  plans                  Plan[]
  clientes               Cliente[]
  memberships            Membership[]
  sucursales             Sucursal[]
  metodosPago            MetodoPago[]
  auditLogs              AuditLog[]
  promociones            Promocion[]
  referidos              Referido[]
  reglasRecompensa       ReglaRecompensa[]
  whatsappConfig         WhatsAppConfig?
  faqs                   FaqItem[]
  tickets                SupportTicket[]
  categories             CompanyToCategory[]
  ratings                CompanyRating[]
  referralEvents         ReferralEvent[]
  followers              CompanyFollow[]
  posts                  CompanyPost[]
  campanas               Campana[]
  invitaciones           Invitacion[]
  accesosStaff           UserCompanyAccess[]
  // Benefit Engine (Fase C). Relaciones inversas; ningún flujo las consume aún.
  benefits               Benefit[]
  // Referral Engine (Fase D). Relaciones inversas; ningún flujo las consume aún.
  referralPrograms       ReferralProgram[]
  // Automation Engine (Fase E1). Relaciones inversas; ningún flujo las consume aún.
  automations            Automation[]
  // Motor Universal de Reglas (Fase 1). Relaciones inversas; no cambian el
  // comportamiento actual: ninguna función existente las consulta todavía.
  ruleGroups             RuleGroup[]
  rules                  Rule[]
  ruleExecLogs           RuleExecutionLog[]
  // Framework Universal de Promociones (Fase 4). Relaciones inversas; ningún
  // flujo existente las consulta.
  promotions             Promotion[]
  promotionAudits        PromotionAudit[]
  // Business Data Dictionary (Fase 6). Variables específicas de empresa.
  dictionaryVariables    DataDictionaryVariable[]
  // Membership Engine universal (Fase A). Independiente del modelo Membership
  // legacy (Car Wash). Ningún flujo existente lo consulta.
  membershipPlans        MembershipPlan[]
  membershipInstances    MembershipInstance[]
  // Benefit Transformation Engine (Fase E1.7).
  benefitTransformations BenefitTransformation[]
  transformationPolicies TransformationPolicy[]

  transacciones   Transaction[]
  receiptTemplate ReceiptTemplate?
  compras         ProductoCompra[]

  // Growth Engine 3.0 (sistema viral de referidos).
  growthLinks  GrowthLink[]
  growthConfig GrowthConfig?
  growthRules  GrowthRule[]

  @@index([isPublished, isFeatured])
  @@index([ciudad, provincia])
  @@index([type])
  @@index([createdAt])
  @@map("companies")
}

// Sucursales físicas de una empresa
model Sucursal {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  nombre    String
  direccion String?
  telefono  String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  visits Visit[]

  transacciones Transaction[]

  @@index([companyId])
  @@map("sucursales")
}

// Métodos de pago configurables por empresa (sin tocar código)
model MetodoPago {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  tipo          MetodoPagoTipo
  nombre        String // "Banco Popular", "Pago en sucursal"
  titular       String?
  numeroCuenta  String?
  tipoCuenta    String? // "Ahorro", "Corriente"
  instrucciones String? // texto libre para mostrar al cliente
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships Membership[]
  compras     ProductoCompra[]

  @@index([companyId])
  @@map("metodos_pago")
}

// FASE E8 · Tipo de Beneficio Digital. Concepto unificado: promociones,
// membresías, cupones, bonos, gift cards y entradas comparten el mismo ciclo
// (adquirir → QR → canjear). Añadir un tipo nuevo NO requiere rediseñar.
enum BeneficioTipo {
  PROMOTION
  MEMBERSHIP
  COUPON
  VOUCHER
  GIFT
  EVENT
}

// Promociones publicadas por una empresa, visibles para sus clientes
// (incluyendo clientes afiliados a varias empresas, vía Cliente.companyId).
model Promocion {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  titulo        String
  descripcion   String
  imagenUrl     String?
  vigenciaDesde DateTime  @default(now())
  vigenciaHasta DateTime?
  activo        Boolean   @default(true)
  publicadaEn   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // FASE 2: Marketplace fields
  slug          String?
  tipo          String   @default("general") // ver PROMO_TIPOS en src/lib/promociones.ts
  descuento     Int? // % o monto fijo según tipo
  codigo        String? // Código cupón
  isFeatured    Boolean  @default(false)
  featuredOrder Int?
  viewCount     Int      @default(0)
  shareCount    Int      @default(0)
  tags          String[] @default([])

  // F4.2: Promociones 2.0
  visibilidad String   @default("publica") // "publica" (todo MembeGo) | "privada" (solo miembros)
  maxCanjes   Int? // límite de canjes (null = ilimitado)
  campanaId   String?
  campana     Campana? @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  canjes      Int      @default(0)
  prioridad   Int      @default(0) // mayor = primero en los listados
  archivada   Boolean  @default(false)

  // FASE E5: la promoción como producto comercial comprable.
  // - Ventana de adquisición = vigenciaDesde/vigenciaHasta (ya existentes).
  // - Vigencia del beneficio: días desde la activación O fecha fija; ambos
  //   null = sin vencimiento. El Rule Engine valida ambas ventanas.
  esComprable            Boolean       @default(false)
  precio                 Decimal?      @db.Decimal(10, 2) // 0 = gratis (activación directa)
  usosPorCompra          Int           @default(1)
  beneficioVigenciaDias  Int?
  beneficioVigenciaHasta DateTime?
  // Restricciones de consumo (0=domingo … 6=sábado; vacío = todos los días).
  diasPermitidos         Int[]         @default([])
  horaDesde              String? // "HH:MM"
  horaHasta              String? // "HH:MM"
  // Imágenes subidas al storage del proyecto (galería futura; [0] = principal).
  imagenes               String[]      @default([])
  // FASE E8 · Beneficio Digital: toda promoción es un beneficio con un TIPO.
  // Hoy se usa PROMOTION; la arquitectura queda lista para cupones, gift cards,
  // bonos y entradas a eventos sin rediseño (solo se añaden reglas del tipo).
  beneficioTipo          BeneficioTipo @default(PROMOTION)

  compras     ProductoCompra[]
  guardadaPor PromocionGuardada[]

  // Growth Engine 3.0: beneficio ofrecido en una landing o entregado por regla.
  growthLinks          GrowthLink[] @relation("GrowthLinkBeneficio")
  growthRulesBeneficio GrowthRule[] @relation("GrowthRuleBeneficio")

  @@index([companyId, activo])
  @@index([isFeatured, vigenciaHasta])
  @@index([tipo])
  @@index([createdAt])
  // Feed público de promociones: filtra sin companyId por estado de
  // publicación; sin este índice cada carga del feed escanea la tabla.
  @@index([activo, archivada, visibilidad, publicadaEn])
  @@map("promociones")
}

model Plan {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  nombre           String
  precio           Decimal  @db.Decimal(10, 2)
  lavadosIncluidos Int      @default(0)
  esIlimitado      Boolean  @default(false)
  descripcion      String?
  beneficios       String[]
  vigenciaDias     Int      @default(30) // duración del período
  condiciones      String? // texto de condiciones/restricciones
  activo           Boolean  @default(true)
  // F4.3: presentación del plan en tarjetas públicas y del panel.
  color            String? // hex o token, ej. "#0ea5e9"
  orden            Int      @default(0) // menor = primero
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships            Membership[]
  membershipsSolicitadas Membership[] @relation("PlanSolicitado")

  @@index([companyId])
  @@map("plans")
}

// Invitación de un miembro al equipo de una empresa (Onboarding Fase 2C).
// El invitado abre el enlace del correo, crea su cuenta y se une con el rol
// asignado. No bloquea la publicación (el equipo puede armarse más tarde).
model Invitacion {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  email       String
  rol         AppRole
  token       String           @unique @default(cuid())
  estado      InvitacionEstado @default(PENDIENTE)
  invitadoPor String? // userId de quien invitó
  expiraEn    DateTime
  aceptadaEn  DateTime?
  createdAt   DateTime         @default(now())

  @@index([companyId, estado])
  @@index([email])
  @@map("invitaciones")
}

model Cliente {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  supabaseId         String
  nombre             String
  telefono           String?
  email              String
  fechaNacimiento    DateTime?
  avatarUrl          String?
  // F5/Onboarding paso 2 (B2C): perfil ampliado del cliente.
  ciudad             String?
  genero             String? // "M" | "F" | "otro" | null (opcional)
  idioma             String? // locale preferido, ej. "es-DO"
  notifPromos        Boolean   @default(true) // recibir promociones
  notifRecordatorios Boolean   @default(true) // recordatorios (vencimiento, etc.)
  codigoReferido     String    @unique @default(cuid())
  // Código corto legible para el enlace /r/XXXXXX (se genera al visitar el
  // panel de referidos; null hasta entonces).
  codigoCorto        String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  vehiculos       Vehiculo[]
  memberships     Membership[]
  qrTokens        QrToken[] // vacío hasta que tenga membresía activa
  visits          Visit[]
  referidosHechos Referido[]      @relation("Referente")
  referidoComo    Referido[]      @relation("Referido")
  referralEvents  ReferralEvent[] @relation("ReferralEvents")
  tickets         SupportTicket[]
  ratings         CompanyRating[]
  notas           ClienteNota[]

  transacciones Transaction[]
  compras       ProductoCompra[]

  // Growth Engine 3.0.
  growthLinks   GrowthLink[]   @relation("GrowthLinks")
  growthRewards GrowthReward[] @relation("GrowthRewards")
  growthWallets GrowthWallet[] @relation("GrowthWallet")

  @@unique([supabaseId, companyId])
  // Filtros frecuentes solo por empresa (adminMetrics, reportes, /admin/clientes).
  // El unique (supabaseId, companyId) no cubre búsquedas por companyId solo.
  @@index([companyId])
  @@map("clientes")
}

enum ReferidoEstado {
  PENDIENTE
  COMPLETADO
}

enum CondicionRecompensa {
  N_REFERIDOS_COMPLETADOS
}

enum TipoRecompensa {
  LAVADOS_GRATIS
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO
}

// Evento del programa de referidos: cada acción del embudo (compartir, clic,
// registro, membresía) con sus puntos. Base de estadísticas, niveles y ranking.
// Diseñado para extenderse (campañas, afiliados) vía canal/meta sin migrar.
enum ReferralEventTipo {
  LINK // Fase E6: enlace de referido generado (código corto emitido)
  SHARE // el referente compartió su enlace
  CLICK // alguien abrió /r/[code]
  LANDING_VIEW // Growth Engine 3.0: la landing del referido fue vista
  REGISTRO_INICIADO // Fase E6: landing de registro cargada con atribución
  REGISTRO // un referido creó cuenta
  VERIFICADO // Fase E6: el referido confirmó su correo
  MEMBRESIA // el referido activó membresía
  COMPRA // Fase E6: primera compra confirmada (membresía o promoción E5)
  PRIMER_USO // Growth Engine 3.0: el referido canjeó su beneficio por 1ª vez
  RECOMPENSA // Fase E6: recompensa entregada al referente
  FRAUDE // Fase E6: intento bloqueado o referido marcado sospechoso
  // Centro global MembeGo: el referido se unió a OTRA empresa de la plataforma.
  // companyId = empresa del referente; meta.targetCompanyId = empresa destino.
  REGISTRO_GLOBAL
  MEMBRESIA_GLOBAL
}

model ReferralEvent {
  id                String            @id @default(cuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  clienteId         String // referente dueño del enlace
  cliente           Cliente           @relation("ReferralEvents", fields: [clienteId], references: [id])
  tipo              ReferralEventTipo
  puntos            Int               @default(0)
  canal             String? // native | whatsapp | copy | qr | telegram | ...
  // Fase E6 · Attribution Tracking: identificador anónimo del visitante,
  // sembrado en el clic (cookie) y propagado hasta el registro. Permite
  // visitas ÚNICAS reales y reconstruir el recorrido completo por persona.
  visitorId         String?
  // Fase E6: referido al que pertenece el evento (cuando ya existe cuenta).
  referidoClienteId String?
  // Growth Engine 3.0: enlace de invitación concreto que originó el evento.
  growthLinkId      String?
  growthLink        GrowthLink?       @relation(fields: [growthLinkId], references: [id], onDelete: SetNull)
  meta              Json              @default("{}") // dispositivo, campaña, ip hash...
  createdAt         DateTime          @default(now())

  @@index([clienteId, companyId])
  @@index([companyId, tipo, createdAt])
  @@index([companyId, tipo, visitorId])
  @@index([referidoClienteId])
  @@index([growthLinkId, tipo])
  @@map("referral_events")
}

// Referido: vínculo entre quien invita y quien se registró con su código.
model Referido {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  referenteClienteId String
  referenteCliente   Cliente        @relation("Referente", fields: [referenteClienteId], references: [id])
  referidoClienteId  String         @unique
  referidoCliente    Cliente        @relation("Referido", fields: [referidoClienteId], references: [id])
  estado             ReferidoEstado @default(PENDIENTE)
  recompensaAplicada Boolean        @default(false)
  // Anti-fraude: registro atribuido pero con huella repetida (misma red/
  // dispositivo del referente o de otro referido reciente). Se conserva el
  // vínculo para auditoría, pero NO cuenta en el embudo ni otorga puntos.
  sospechoso         Boolean        @default(false)
  createdAt          DateTime       @default(now())
  completadoEn       DateTime?

  @@index([companyId, referenteClienteId])
  @@index([companyId, sospechoso])
  @@map("referidos")
}

// Fase E6: recompensa REAL del programa de referidos, con estado propio.
// Reemplaza el booleano recompensaAplicada como fuente de verdad: cada umbral
// alcanzado genera una fila (>= sin pérdidas), auditable y sin doble entrega.
enum ReferralRecompensaEstado {
  PENDIENTE // otorgada pero de entrega manual (descuentos) o esperando entrega
  ENTREGADA // efecto aplicado (p. ej. usos sumados a la membresía)
  RECHAZADA // anulada por el admin (p. ej. fraude posterior)
}

model ReferralRecompensa {
  id                   String                   @id @default(cuid())
  companyId            String
  referenteClienteId   String
  reglaId              String
  regla                ReglaRecompensa          @relation(fields: [reglaId], references: [id])
  estado               ReferralRecompensaEstado @default(PENDIENTE)
  tipo                 TipoRecompensa
  valor                Int
  descripcion          String
  // Umbral de referidos completados que la disparó (auditoría del cálculo).
  umbral               Int
  completadosAlOtorgar Int
  entregadaAt          DateTime?
  motivoRechazo        String?
  createdAt            DateTime                 @default(now())

  // Una recompensa por regla por referente: el umbral >= no duplica entregas.
  @@unique([referenteClienteId, reglaId])
  @@index([companyId, estado])
  @@index([referenteClienteId])
  @@map("referral_recompensas")
}

// Regla de recompensa 100% configurable desde el panel admin: sin valores
// fijos en código. El admin define cuándo y qué recompensa otorgar.
model ReglaRecompensa {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  nombre          String
  condicion       CondicionRecompensa
  valorCondicion  Int // ej: 3 referidos completados
  tipoRecompensa  TipoRecompensa
  valorRecompensa Decimal             @db.Decimal(10, 2) // lavados, % o monto según tipo
  activo          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  recompensas ReferralRecompensa[]

  @@index([companyId, activo])
  @@map("reglas_recompensa")
}

// ═══════════════════════════════════════════════════════════════════════════
// GROWTH ENGINE 3.0 · Sistema viral de referidos
// Módulo de crecimiento sobre el motor de eventos EN VIVO (ReferralEvent /
// Referido). Cada enlace compartido es una campaña de adquisición (GrowthLink)
// con su propia landing, expiración y embudo. Las recompensas NO están
// codificadas: reglas configurables por evento (GrowthRule) que se ENTREGAN
// como Beneficios Digitales de E8 (ProductoCompra con QR), puntos o créditos.
// ═══════════════════════════════════════════════════════════════════════════

/// Disparadores de una regla de recompensa (eventos reales del embudo).
enum GrowthTrigger {
  LINK_ABIERTO // el invitado abrió la landing / hizo clic
  REGISTRO // el invitado completó el registro
  VERIFICADO // el invitado verificó su correo
  MEMBRESIA // el invitado adquirió una membresía
  COMPRA // el invitado hizo una compra (promoción o plan)
  PRIMER_USO // el invitado canjeó su beneficio por primera vez
  N_REFERIDOS // umbral de referidos completados (campañas)
}

/// Qué recompensa entrega una regla. BENEFICIO usa el Motor de Beneficios
/// Digitales (E8): otorga una Promoción como ProductoCompra activo con QR.
enum GrowthRewardTipo {
  PUNTOS
  CREDITOS
  BENEFICIO // Beneficio Digital (Promoción E8) entregado como ProductoCompra
  LAVADOS_GRATIS // compat E6: incrementa usos de la membresía activa
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO
}

/// A quién se le entrega la recompensa de una regla.
enum GrowthBeneficiario {
  REFERENTE // quien invita
  REFERIDO // el invitado
  AMBOS
}

enum GrowthRewardEstado {
  PENDIENTE // otorgada; espera entrega (manual) o activación del beneficio
  ENTREGADA // efecto aplicado (beneficio activo, puntos/créditos sumados)
  RECHAZADA // anulada (fraude posterior u otra razón)
}

/// Un enlace de invitación concreto. A diferencia del código único del cliente
/// (legacy), cada GrowthLink tiene su beneficio, expiración y embudo propios.
model GrowthLink {
  id            String     @id @default(cuid())
  code          String     @unique // código corto para /r/[code]
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId     String // referente dueño del enlace
  cliente       Cliente    @relation("GrowthLinks", fields: [clienteId], references: [id], onDelete: Cascade)
  // Beneficio ofrecido en la landing (Beneficio Digital E8). Opcional.
  promocionId   String?
  promocion     Promocion? @relation("GrowthLinkBeneficio", fields: [promocionId], references: [id], onDelete: SetNull)
  campanaId     String?
  campana       Campana?   @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  titulo        String?
  mensaje       String?
  canal         String? // canal con el que se generó/compartió
  duracionHoras Int? // duración configurable (1, 6, 12, 24, 72, 168…)
  expiresAt     DateTime? // instante exacto de expiración (verificado en servidor)
  activo        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  eventos     ReferralEvent[]
  recompensas GrowthReward[]

  @@index([companyId, clienteId])
  @@index([campanaId])
  @@map("growth_links")
}

/// Configuración del programa de crecimiento por empresa (req #12). Cada
/// empresa decide qué premia y la duración por defecto de sus enlaces.
model GrowthConfig {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  landingActiva        Boolean  @default(true) // mostrar landing antes del registro
  duracionHorasDefault Int      @default(24) // expiración por defecto de enlaces
  premiaClic           Boolean  @default(false)
  premiaRegistro       Boolean  @default(true)
  premiaMembresia      Boolean  @default(true)
  premiaCompra         Boolean  @default(true)
  premiaRenovacion     Boolean  @default(false)
  config               Json     @default("{}") // extensible sin migrar
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("growth_configs")
}

/// Regla de recompensa 100% configurable por evento (req #9). Sin valores fijos
/// en código: el admin define trigger, condición, beneficiario y recompensa.
model GrowthRule {
  id                    String             @id @default(cuid())
  companyId             String
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campanaId             String?
  campana               Campana?           @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  nombre                String
  trigger               GrowthTrigger
  valorCondicion        Int                @default(1) // ej. N_REFERIDOS => umbral
  planId                String? // condición: solo si compró este plan (ej. Gold)
  beneficiario          GrowthBeneficiario @default(REFERENTE)
  recompensaTipo        GrowthRewardTipo
  recompensaValor       Decimal            @default(0) @db.Decimal(10, 2)
  // Beneficio Digital (Promoción) a otorgar cuando recompensaTipo = BENEFICIO.
  recompensaPromocionId String?
  recompensaPromocion   Promocion?         @relation("GrowthRuleBeneficio", fields: [recompensaPromocionId], references: [id], onDelete: SetNull)
  activo                Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  recompensas GrowthReward[]

  @@index([companyId, activo])
  @@index([companyId, trigger, activo])
  @@map("growth_rules")
}

/// Recompensa REAL otorgada por el Growth Engine, con estado propio y entrega
/// idempotente. Cuando el tipo es BENEFICIO, `productoCompraId` referencia el
/// ProductoCompra (E8) generado como beneficio activo con QR.
model GrowthReward {
  id               String             @id @default(cuid())
  companyId        String
  ruleId           String
  rule             GrowthRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  clienteId        String // beneficiario (referente o referido)
  cliente          Cliente            @relation("GrowthRewards", fields: [clienteId], references: [id], onDelete: Cascade)
  growthLinkId     String?
  growthLink       GrowthLink?        @relation(fields: [growthLinkId], references: [id], onDelete: SetNull)
  referidoId       String? // vínculo Referido que la disparó (auditoría)
  trigger          GrowthTrigger
  tipo             GrowthRewardTipo
  valor            Decimal            @db.Decimal(10, 2)
  descripcion      String
  estado           GrowthRewardEstado @default(PENDIENTE)
  productoCompraId String? // scalar: beneficio E8 entregado (si aplica)
  entregadaAt      DateTime?
  motivoRechazo    String?
  // Idempotencia: una recompensa por disparador único (regla+cliente+evento).
  dedupeKey        String             @unique
  createdAt        DateTime           @default(now())

  @@index([companyId, estado])
  @@index([clienteId])
  @@index([growthLinkId])
  @@map("growth_rewards")
}

/// Saldo de puntos y créditos del programa (wallet) por empresa y cliente.
model GrowthWallet {
  id        String   @id @default(cuid())
  companyId String
  clienteId String
  cliente   Cliente  @relation("GrowthWallet", fields: [clienteId], references: [id], onDelete: Cascade)
  puntos    Int      @default(0)
  creditos  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, clienteId])
  @@index([companyId])
  @@map("growth_wallets")
}

// Configuración de Comunicación y Soporte por empresa, 100% editable desde el
// panel. Conserva el nombre de tabla `whatsapp_config` por compatibilidad.
model WhatsAppConfig {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id])
  codigoPais       String   @default("+1") // ej: +52
  numero           String // solo dígitos nacionales, ej: 5512345678
  mensajePlantilla String   @default("Hola, quisiera más información.")
  activo           Boolean  @default(true) // mostrar botón de WhatsApp al cliente
  correoSoporte    String? // correo de soporte, ej: soporte@empresa.com
  horaInicio       String? // "09:00"
  horaCierre       String? // "18:00"
  diasLaborales    String? // CSV de índices de día 0..6 (0=Dom), ej: "1,2,3,4,5"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("whatsapp_config")
}

// Preguntas frecuentes administrables por empresa, visibles en el Centro de Ayuda.
model FaqItem {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  pregunta  String
  respuesta String
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, activo])
  @@map("faq_items")
}

// Tickets de soporte creados por clientes y gestionados por administradores.
model SupportTicket {
  id         String          @id @default(cuid())
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id])
  clienteId  String
  cliente    Cliente         @relation(fields: [clienteId], references: [id])
  asunto     String
  categoria  TicketCategoria @default(OTRO)
  estado     TicketEstado    @default(NUEVO)
  adjuntoUrl String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  mensajes TicketMensaje[]

  @@index([companyId, estado])
  @@index([clienteId])
  @@map("support_tickets")
}

// Mensajes/eventos de un ticket: conversación cliente↔admin, notas internas
// (solo visibles para admin) y eventos de sistema (cambios de estado).
model TicketMensaje {
  id            String        @id @default(cuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  autorTipo     TicketAutor
  autorNombre   String
  cuerpo        String
  esNotaInterna Boolean       @default(false)
  createdAt     DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_mensajes")
}

model Vehiculo {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  marca     String
  modelo    String
  anio      Int
  color     String
  placa     String?
  createdAt DateTime @default(now())

  visits Visit[]

  @@index([clienteId])
  @@map("vehiculos")
}

model Membership {
  id                  String           @id @default(cuid())
  clienteId           String
  cliente             Cliente          @relation(fields: [clienteId], references: [id])
  companyId           String
  company             Company          @relation(fields: [companyId], references: [id])
  planId              String
  plan                Plan             @relation(fields: [planId], references: [id])
  // Cambio de plan solicitado por el cliente mientras la membresía sigue ACTIVA.
  // El admin lo aprueba (con el comprobante) y se aplica; hasta entonces el plan
  // vigente no cambia. null = sin cambio pendiente.
  planIdSolicitado    String?
  planSolicitado      Plan?            @relation("PlanSolicitado", fields: [planIdSolicitado], references: [id])
  userId              String? // empleado/admin que la creó
  user                User?            @relation(fields: [userId], references: [id])
  metodoPagoId        String? // método de pago seleccionado
  metodoPago          MetodoPago?      @relation(fields: [metodoPagoId], references: [id])
  estado              MembershipEstado @default(PENDIENTE)
  // Pago
  comprobanteUrl      String? // URL del comprobante subido (Supabase Storage)
  comprobanteNota     String? // nota del cliente al enviar comprobante
  rechazadoReason     String? // motivo de rechazo por admin
  adminNota           String? // nota interna del admin, no visible al cliente
  pagoConfirmado      Boolean          @default(false)
  montoPagado         Decimal?         @db.Decimal(10, 2)
  // O-13: descuento de bienvenida congelado al solicitar el plan (null = sin
  // descuento). Solo se aplica si la membresía nunca se activó (fechaInicio null).
  descuentoBienvenida Decimal?         @db.Decimal(10, 2)
  // Período activo
  fechaInicio         DateTime?
  fechaVencimiento    DateTime?
  lavadosRestantes    Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  visits       Visit[]
  comprobantes Comprobante[]
  qrTokens     QrToken[]

  transacciones Transaction[]

  @@unique([clienteId, companyId])
  @@index([estado])
  @@index([clienteId])
  @@index([companyId])
  // Conteos por plan (reportes, borrado seguro de planes).
  @@index([planId])
  // Patrón caliente de dashboards y automatizaciones: membresías de una
  // empresa por estado y vencimiento (activas, por vencer, pendientes).
  @@index([companyId, estado, fechaVencimiento])
  @@map("memberships")
}

// ─────────────────────────────────────────────
// FASE E5 · PRODUCTOS COMERCIALES (compras)
// Ciclo de compra unificado: hoy lo usan las promociones; las membresías
// comparten el mismo flujo conceptual (solicitud → pago → validación →
// activación → QR → consumo) y podrán migrar a esta tabla sin rediseño.
// ─────────────────────────────────────────────

enum ProductoComercialTipo {
  PROMOCION
  MEMBRESIA // reservado: unificación futura del ciclo de membresías
}

enum CompraEstado {
  SOLICITADA // el cliente pidió el producto
  PENDIENTE_PAGO // esperando la transferencia del cliente
  EN_VALIDACION // comprobante enviado, esperando al admin
  APROBADA // pago validado (transitorio antes de activar)
  ACTIVA // beneficio disponible, QR emitido
  RECHAZADA // pago rechazado (puede reintentar)
  CONSUMIDA // sin usos restantes
  EXPIRADA // venció sin consumirse por completo
  CANCELADA // cancelada por el cliente o el admin
}

model ProductoCompra {
  id     String                @id @default(cuid())
  tipo   ProductoComercialTipo @default(PROMOCION)
  estado CompraEstado          @default(SOLICITADA)

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  clienteId   String
  cliente     Cliente    @relation(fields: [clienteId], references: [id])
  promocionId String?
  promocion   Promocion? @relation(fields: [promocionId], references: [id])

  // Pago (transferencia hoy; el puerto de pagos permite pasarelas futuras)
  metodoPagoId       String?
  metodoPago         MetodoPago? @relation(fields: [metodoPagoId], references: [id])
  precioCongelado    Decimal?    @db.Decimal(10, 2) // precio al solicitar
  montoPagado        Decimal?    @db.Decimal(10, 2)
  pagoConfirmado     Boolean     @default(false)
  comprobanteUrl     String?
  comprobanteNota    String?
  transferenciaFecha DateTime? // fecha/hora declarada de la transferencia
  rechazadoReason    String?
  adminNota          String?
  aprobadaPorId      String?
  aprobadaPor        User?       @relation("CompraAprobadaPor", fields: [aprobadaPorId], references: [id])

  // Beneficio activo
  usosIncluidos    Int       @default(1)
  usosRestantes    Int       @default(0)
  fechaActivacion  DateTime?
  fechaVencimiento DateTime? // null = sin vencimiento
  consumidaAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transiciones ProductoCompraTransicion[]
  qrTokens     QrToken[]

  @@index([companyId, estado])
  @@index([clienteId, estado])
  @@index([promocionId, estado])
  @@index([companyId, createdAt])
  @@map("producto_compras")
}

// Bitácora inmutable de estados de una compra (quién, cuándo, por qué).
model ProductoCompraTransicion {
  id        String         @id @default(cuid())
  compraId  String
  compra    ProductoCompra @relation(fields: [compraId], references: [id], onDelete: Cascade)
  desde     CompraEstado?
  hacia     CompraEstado
  motivo    String?
  userId    String?
  user      User?          @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())

  @@index([compraId, createdAt])
  @@map("producto_compra_transiciones")
}

// QR de acceso de un producto activo: membresía O compra de promoción (E5).
// Exactamente el mismo sistema de un solo uso con regeneración para ambos.
model QrToken {
  id               String          @id @default(cuid())
  clienteId        String
  cliente          Cliente         @relation(fields: [clienteId], references: [id])
  membresiaId      String?
  membership       Membership?     @relation(fields: [membresiaId], references: [id], onDelete: Cascade)
  // FASE E5: QR de una compra de promoción (excluyente con membresiaId).
  compraId         String?
  compra           ProductoCompra? @relation(fields: [compraId], references: [id], onDelete: Cascade)
  token            String          @unique @default(cuid())
  activo           Boolean         @default(true)
  // Compartir el QR (p. ej. por WhatsApp) no consume el token —sigue siendo de
  // un solo uso— pero sí queda registrado: cuántas veces y cuándo la última.
  compartidoCount  Int             @default(0)
  ultimoCompartido DateTime?
  createdAt        DateTime        @default(now())

  transaccionUso Transaction? @relation("TransactionQrUsado")

  @@index([clienteId, activo])
  @@index([membresiaId])
  @@index([compraId])
  @@map("qr_tokens")
}

model Visit {
  id           String     @id @default(cuid())
  clienteId    String
  cliente      Cliente    @relation(fields: [clienteId], references: [id])
  vehiculoId   String?
  vehiculo     Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  sucursalId   String?
  sucursal     Sucursal?  @relation(fields: [sucursalId], references: [id])
  empleadoId   String?
  empleado     User?      @relation("EmpleadoVisits", fields: [empleadoId], references: [id])
  servicio     String
  descontado   Boolean    @default(false)
  fechaVisita  DateTime   @default(now())
  notas        String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  comprobante Comprobante?

  // Postgres no indexa FKs automáticamente. Visitas se consultan por cliente,
  // por membresía y por fecha (historial, reportes, "clientes frecuentes").
  transaccion Transaction?

  @@index([clienteId])
  @@index([membershipId])
  @@index([fechaVisita])
  @@index([vehiculoId])
  @@index([sucursalId])
  @@map("visits")
}

// Comprobante generado al confirmar visita. Registra impresiones.
model Comprobante {
  id              String     @id @default(cuid())
  visitId         String     @unique
  visit           Visit      @relation(fields: [visitId], references: [id])
  membershipId    String
  membership      Membership @relation(fields: [membershipId], references: [id])
  numero          String     @unique // número secuencial legible (ej. "COMP-000123")
  impresiones     Int        @default(0)
  ultimaImpresion DateTime?
  creadoPorId     String?
  creadoPor       User?      @relation(fields: [creadoPorId], references: [id])
  createdAt       DateTime   @default(now())

  @@index([membershipId])
  @@map("comprobantes")
}

// Registro de auditoría inmutable — insert only, nunca se actualiza ni elimina
model AuditLog {
  id          String      @id @default(cuid())
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  userId      String? // quien realizó la acción
  user        User?       @relation(fields: [userId], references: [id])
  accion      AuditAccion
  entidadTipo String // "Visit", "Membership", "QrToken", etc.
  entidadId   String
  payload     Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([accion])
  @@index([entidadTipo, entidadId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notificacion {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tipo      NotifTipo
  titulo    String
  mensaje   String
  href      String? // ruta a la que lleva al hacer clic
  leida     Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  @@map("notificaciones")
}

// ─────────────────────────────────────────────
// FASE 2: MARKETPLACE
// ─────────────────────────────────────────────

model BusinessCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies   CompanyToCategory[]
  interesados UserInteres[]

  @@index([active, order])
  @@map("business_categories")
}

model CompanyToCategory {
  id         String           @id @default(cuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId String
  category   BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([companyId, categoryId])
  @@index([companyId])
  @@index([categoryId])
  @@map("company_to_categories")
}

model CompanyRating {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  comment   String?
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, clienteId])
  @@index([companyId])
  @@index([rating])
  @@map("company_ratings")
}

// ─── FASE 3: Capa social del marketplace ────────────────────────────────────
// Seguir empresas: el cliente (User, cross-empresa) sigue negocios para
// recibir sus promociones y novedades. esFavorita las prioriza en toda la app.
model CompanyFollow {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  esFavorita Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId, esFavorita])
  @@map("company_follows")
}

// Promociones guardadas por el cliente ("Mis promociones guardadas").
model PromocionGuardada {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promocionId String
  promocion   Promocion @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, promocionId])
  @@index([userId, createdAt])
  @@index([promocionId])
  @@map("promociones_guardadas")
}

// F3.3: Publicaciones de empresa — eventos, noticias y beneficios permanentes.
// Un solo modelo flexible: fechaEvento/lugar solo aplican a EVENTO.
enum PostTipo {
  EVENTO
  NOTICIA
  BENEFICIO
}

model CompanyPost {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipo        PostTipo
  titulo      String
  contenido   String
  imagenUrl   String?
  fechaEvento DateTime? // solo EVENTO
  lugar       String? // solo EVENTO
  campanaId   String?
  campana     Campana?  @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  activo      Boolean   @default(true)
  publicadaEn DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId, tipo, activo])
  @@index([tipo, fechaEvento])
  @@map("company_posts")
}

// F4.4: notas internas del CRM — múltiples por cliente, con autor y fecha.
// Solo visibles para el equipo de la empresa (nunca para el cliente).
model ClienteNota {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  autorId   String?
  autor     User?    @relation(fields: [autorId], references: [id], onDelete: SetNull)
  texto     String
  createdAt DateTime @default(now())

  @@index([clienteId, createdAt])
  @@map("cliente_notas")
}

// F4.6: campañas — agrupan promociones y publicaciones bajo un mismo
// paraguas (ej. "Black Friday") para medirlas en conjunto.
model Campana {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  fechaInicio DateTime?
  fechaFin    DateTime?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  promociones Promocion[]
  posts       CompanyPost[]

  // Growth Engine 3.0: enlaces y reglas ligados a esta campaña.
  growthLinks GrowthLink[]
  growthRules GrowthRule[]

  @@index([companyId, activo])
  @@map("campanas")
}

// F5.2: intereses del cliente (categorías favoritas, cross-empresa).
// Alimentan las recomendaciones del feed y el onboarding B2C.
model UserInteres {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([userId, categoryId])
  @@index([categoryId])
  @@map("user_intereses")
}

// ─────────────────────────────────────────────
// FASE 1 (REDISEÑO DEL NÚCLEO): MOTOR UNIVERSAL DE REGLAS
// ─────────────────────────────────────────────
// Infraestructura genérica y multi-tenant para el futuro Rule Engine. NO
// contiene lógica de promociones, membresías, QR ni cupones: solo el modelo
// de datos de reglas configurables. Ningún flujo actual lee estas tablas.

/// Ciclo de vida de una regla (independiente del interruptor `activo`).
enum RuleStatus {
  DRAFT // en edición, nunca se evalúa
  PUBLISHED // publicada; se evalúa si además `activo` = true y está en ventana de vigencia
  ARCHIVED // retirada; se conserva como historial, nunca se evalúa
}

/// Cómo se combinan las condiciones de una regla (modo plano, Fase 1). Cuando
/// la regla usa grupos (Fase 2) este campo se ignora en favor del árbol.
enum RuleMatchType {
  ALL // AND: todas las condiciones deben cumplirse
  ANY // OR: basta con que se cumpla una condición
}

/// Operador lógico de un grupo de condiciones (Fase 2). Permite construir
/// árboles booleanos de profundidad ilimitada.
enum RuleLogicalOperator {
  AND // todas las condiciones/hijos deben cumplirse
  OR // al menos uno debe cumplirse
  NOT // negación del conjunto de hijos (NOT del AND de los hijos)
  XOR // exactamente uno de los hijos debe cumplirse
}

/// Agrupa reglas por dominio funcional (ej. "Validación QR", "Membresías",
/// "Beneficios"). Puramente organizativo; el motor puede filtrar por `key`.
model RuleGroup {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key         String // identificador estable legible por máquina, ej. "qr_validation"
  nombre      String
  descripcion String?
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules Rule[]

  @@unique([companyId, key])
  @@index([companyId, activo])
  @@map("rule_groups")
}

/// Regla configurable. El motor la evalúa contra un RuleContext y, si se
/// cumple, dispara sus acciones. No conoce el negocio: campos y valores son
/// genéricos (dot-paths + JSON).
model Rule {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupId     String?
  group       RuleGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  nombre      String
  descripcion String?
  status      RuleStatus    @default(DRAFT)
  activo      Boolean       @default(true) // interruptor de encendido, independiente del ciclo de vida
  prioridad   Int           @default(0) // mayor = se evalúa primero
  version     Int           @default(1) // se incrementa en cada cambio (base para versionado)
  matchType   RuleMatchType @default(ALL)
  validoDesde DateTime? // ventana de vigencia opcional (null = sin límite inferior)
  validoHasta DateTime? // null = sin límite superior
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  conditions      RuleCondition[]
  conditionGroups RuleConditionGroup[]
  actions         RuleAction[]
  logs            RuleExecutionLog[]
  // Fase 4: reglas reutilizadas por promociones (sin duplicar).
  promotionRules  PromotionRule[]

  // Consulta caliente del motor: reglas de una empresa evaluables por estado.
  @@index([companyId, status, activo])
  @@index([groupId])
  @@index([companyId, prioridad])
  @@map("rules")
}

/// Condición atómica de una regla. `campo` es un dot-path dentro del contexto
/// (ej. "cliente.puntos"), `operador` es la clave de un operador del registro
/// extensible (ej. "gte") y `valor` es el valor esperado en JSON.
model RuleCondition {
  id            String              @id @default(cuid())
  ruleId        String
  rule          Rule                @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  // Fase 2: grupo al que pertenece la condición dentro del árbol booleano.
  // null = cuelga directamente de la raíz de la regla (modo plano de Fase 1).
  groupId       String?
  group         RuleConditionGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  campo         String // dot-path dentro del RuleContext, ej. "cliente.membresiaActiva"
  operador      String // id del operador en el registro, ej. "eq", "gte", "in"
  valor         Json                @default("null") // valor esperado (comparación)
  tipoValor     String              @default("STRING") // legacy Fase 1: guía de coerción del valor JSON
  // Fase 2: tipo de condición (registro extensible, ej. "field") y tipo de dato
  // evaluado (TEXT|NUMBER|DATE|TIME|BOOLEAN|LIST|OBJECT|ENUM|JSON) para validar
  // compatibilidad operador↔dato.
  conditionType String              @default("field")
  dataType      String              @default("TEXT")
  orden         Int                 @default(0)
  createdAt     DateTime            @default(now())

  @@index([ruleId, orden])
  @@index([groupId])
  @@map("rule_conditions")
}

/// Grupo de condiciones (Fase 2). Nodo interno del árbol booleano de una regla:
/// combina sus condiciones e hijos con un RuleLogicalOperator. Se auto-referencia
/// (`parentId`) para anidar sin límite. Un grupo sin `parentId` es una raíz.
model RuleConditionGroup {
  id        String               @id @default(cuid())
  ruleId    String
  rule      Rule                 @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    RuleConditionGroup?  @relation("RuleGroupTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  RuleConditionGroup[] @relation("RuleGroupTree")
  operator  RuleLogicalOperator  @default(AND)
  orden     Int                  @default(0)
  createdAt DateTime             @default(now())

  conditions RuleCondition[]

  @@index([ruleId])
  @@index([parentId])
  @@map("rule_condition_groups")
}

/// Acción a ejecutar cuando la regla se cumple. En esta fase SOLO se almacena
/// la estructura: no hay handlers reales registrados. `tipo` es la clave de un
/// handler del registro extensible; `params` su configuración en JSON.
model RuleAction {
  id            String   @id @default(cuid())
  ruleId        String
  rule          Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tipo          String // clave del handler en el registro, ej. "grant_benefit" (aún sin implementar)
  params        Json     @default("{}")
  orden         Int      @default(0) // prioridad/orden de ejecución (menor = antes)
  // Fase 3: configuración de la acción por DATOS (no por código).
  obligatoria   Boolean  @default(true) // true = su fallo marca la ejecución como fallida
  maxReintentos Int      @default(0) // reintentos ante error (0 = un solo intento)
  activa        Boolean  @default(true) // interruptor: si false, se omite (SKIPPED)
  version       Int      @default(1) // versión de la configuración de la acción
  createdAt     DateTime @default(now())

  @@index([ruleId, orden])
  @@map("rule_actions")
}

/// Registro de auditoría de cada evaluación del motor. Estructura preparada
/// para observabilidad; el motor la persiste solo si se le inyecta un sink
/// Prisma (por defecto usa un sink no-op).
model RuleExecutionLog {
  id         String   @id @default(cuid())
  ruleId     String?
  rule       Rule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  matched    Boolean // si la regla se cumplió
  resultado  Json     @default("{}") // resumen de acciones/resultado
  contexto   Json     @default("{}") // snapshot (posiblemente saneado) del contexto
  duracionMs Int      @default(0)
  error      String? // mensaje si la evaluación/ejecución falló
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([ruleId])
  @@map("rule_execution_logs")
}

// ─────────────────────────────────────────────
// FASE 4: FRAMEWORK UNIVERSAL DE PROMOCIONES
// ─────────────────────────────────────────────
// Una promoción es una entidad CONFIGURABLE sin lógica programada: compone
// información general + reglas (Rule Engine) + acciones (Action Engine) +
// restricciones + ciclo de vida + versionado + auditoría. Es independiente de
// la industria y del modelo `Promocion` (marketplace) existente, que NO se
// toca. Multi-tenant: todo cuelga de companyId. Ningún flujo la consume aún.

/// Ciclo de vida de una promoción. Extensible.
enum PromotionStatus {
  DRAFT // borrador
  PENDING // pendiente de revisión/aprobación
  SCHEDULED // programada (con fecha futura)
  ACTIVE // activa
  PAUSED // pausada temporalmente
  SUSPENDED // suspendida (por incidencia/decisión)
  ENDED // finalizada (fin natural)
  ARCHIVED // archivada (histórico)
  CANCELLED // cancelada
}

/// Definición general y ADMINISTRATIVA de una promoción. Sin lógica: la lógica
/// vive en las reglas (Rule Engine) y las acciones (Action Engine) asociadas.
model Promotion {
  id           String          @id @default(cuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  categoria    String? // etiqueta libre de organización, NUNCA tipo de industria
  status       PromotionStatus @default(DRAFT)
  prioridad    Int             @default(0) // mayor = más prioritaria ante conflictos
  inicioEn     DateTime? // ventana de vigencia (programación)
  finEn        DateTime?
  config       Json            @default("{}") // configuración flexible (parámetros arbitrarios)
  metadata     Json            @default("{}") // metadatos libres
  version      Int             @default(1) // versión actual
  creadoPorId  String? // usuario que la creó
  editadoPorId String? // último usuario que la modificó
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  rules        PromotionRule[]
  actions      PromotionAction[]
  restrictions PromotionRestriction[]
  versions     PromotionVersion[]
  audits       PromotionAudit[]

  @@index([companyId, status])
  @@index([companyId, prioridad])
  @@index([companyId, status, inicioEn, finEn])
  @@map("promotions")
}

/// Mapeo promoción→regla (Rule Engine). Reutiliza reglas SIN duplicarlas.
model PromotionRule {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  ruleId      String
  rule        Rule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  orden       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([promotionId, ruleId]) // no duplicar la misma regla en una promoción
  @@index([ruleId])
  @@map("promotion_rules")
}

/// Mapeo promoción→acción (Action Engine). La promoción NUNCA ejecuta acciones
/// directamente: aporta la configuración que el Action Engine ejecutará.
model PromotionAction {
  id            String    @id @default(cuid())
  promotionId   String
  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tipo          String // clave del catálogo del Action Engine
  params        Json      @default("{}")
  orden         Int       @default(0)
  obligatoria   Boolean   @default(true)
  maxReintentos Int       @default(0)
  activa        Boolean   @default(true)
  version       Int       @default(1)
  createdAt     DateTime  @default(now())

  @@index([promotionId, orden])
  @@map("promotion_actions")
}

/// Restricción universal de una promoción (config, sin validación programada
/// todavía). `tipo` proviene de un catálogo (MAX_USES_TOTAL, PER_CLIENT, …).
model PromotionRestriction {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tipo        String // clave del catálogo de restricciones
  valor       Int? // límite numérico cuando aplica (usos, cantidad…)
  config      Json      @default("{}") // parámetros adicionales (ventana, ámbito…)
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([promotionId])
  @@map("promotion_restrictions")
}

/// Instantánea inmutable de una versión de la promoción. Nunca se borra: es el
/// historial de versionado.
model PromotionVersion {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json // definición completa congelada en esa versión
  resumen     String? // resumen del cambio
  creadoPorId String?
  createdAt   DateTime  @default(now())

  @@unique([promotionId, version])
  @@index([promotionId])
  @@map("promotion_versions")
}

/// Auditoría completa: quién, qué, cuándo, estado anterior/nuevo y diff.
model PromotionAudit {
  id             String           @id @default(cuid())
  promotionId    String
  promotion      Promotion        @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId         String?
  accion         String // CREATED | UPDATED | STATUS_CHANGED | VERSIONED | ARCHIVED | ...
  estadoAnterior PromotionStatus?
  estadoNuevo    PromotionStatus?
  cambios        Json             @default("{}") // diff de campos modificados
  createdAt      DateTime         @default(now())

  @@index([promotionId, createdAt])
  @@index([companyId, createdAt])
  @@map("promotion_audits")
}

// ─────────────────────────────────────────────
// FASE 6: BUSINESS DATA DICTIONARY (DICCIONARIO UNIVERSAL DE DATOS)
// ─────────────────────────────────────────────
// Fuente OFICIAL de todas las variables de negocio que pueden usar reglas,
// promociones, membresías, QR, etc. El catálogo ESTÁNDAR vive en código
// (src/lib/dictionary/domain/catalog.ts); estas tablas persisten las variables
// CUSTOM/por-empresa registradas en runtime. Sin lógica de negocio. Ningún flujo
// de la app las consume todavía.

/// Estado de una variable del diccionario.
enum DictionaryVariableStatus {
  ACTIVE // disponible para usarse
  DEPRECATED // en desuso; se resuelve pero no debería usarse en variables nuevas
  DISABLED // desactivada; no se resuelve
}

/// Definición centralizada de una variable de negocio. NUNCA depende de nombres
/// de columnas del ORM: `contextPath` apunta al Modelo Universal de Contexto.
model DataDictionaryVariable {
  id           String                   @id @default(cuid())
  companyId    String? // null = variable GLOBAL/estándar; con valor = específica de empresa
  company      Company?                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key          String // nombre técnico, ej. "cliente.puntos"
  displayName  String // nombre visible
  description  String?
  semanticType String // tipo semántico (TEXT|INTEGER|MONEY|PERCENT|…) → mapea a DataType del Rule Engine
  category     String // categoría (Cliente, Empresa, Sistema…)
  subcategory  String?
  ownerModule  String? // módulo propietario
  source       String                   @default("CONTEXT") // CONTEXT | CALCULATED | CONSTANT | EXTERNAL
  contextPath  String? // ruta en el Context Model, ej. "cliente.puntos"
  format       String?
  unit         String?
  aliases      String[]                 @default([]) // nombres alternativos que resuelven a esta variable
  status       DictionaryVariableStatus @default(ACTIVE)
  version      Int                      @default(1)
  validation   Json                     @default("{}") // reglas de validación (rango, patrón, valores…)
  i18n         Json                     @default("{}") // { es: {name,description,help}, en: {...} }
  calculated   Json? // descriptor de variable calculada (kind + inputs); null si no lo es
  metadata     Json                     @default("{}")
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  versions DataDictionaryVariableVersion[]

  @@unique([companyId, key]) // única por empresa (y una global por key con companyId null)
  @@index([companyId, category])
  @@index([category])
  @@index([status])
  @@map("data_dictionary_variables")
}

/// Instantánea de versión de una variable (historial inmutable).
model DataDictionaryVariableVersion {
  id         String                 @id @default(cuid())
  variableId String
  variable   DataDictionaryVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json
  createdAt  DateTime               @default(now())

  @@unique([variableId, version])
  @@index([variableId])
  @@map("data_dictionary_variable_versions")
}

// ─────────────────────────────────────────────
// FASE A: MEMBERSHIP ENGINE UNIVERSAL
// ─────────────────────────────────────────────
// Motor universal de membresías: modela CUALQUIER modelo comercial (los 20 de la
// Membership Strategy Library) por CONFIGURACIÓN, no por código. Independiente de
// la industria y del modelo `Membership` (Car Wash) existente, que NO se toca.
// Reutiliza Rule/Action/Context/Dictionary/BEL para reglas de uso y automatización.

/// Modelo comercial de la membresía (los 20 de la biblioteca de estrategias).
enum MembershipPlanType {
  UNLIMITED
  CREDITS
  HYBRID
  TIER
  FAMILY
  FLEET
  CORPORATE
  SEASONAL
  PREMIUM
  MAINTENANCE
  PAY_PER_VISIT
  LOYALTY
  PREPAID
  VIP
  REWARDS
  TRIAL
  STUDENT
  DRIVER
  SUBSCRIPTION_BOX
  CUSTOM
}

/// Periodicidad de cobro/renovación.
enum MembershipPeriodicity {
  NONE
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  SEASONAL
}

/// Estado de una membresía de un suscriptor concreto.
enum MembershipInstanceStatus {
  PENDING
  ACTIVE
  PAUSED
  SUSPENDED
  EXPIRED
  CANCELLED
}

/// Definición (plantilla instanciada) de un plan de membresía de una empresa.
/// Toda la configuración específica vive en `config` (JSON): servicios incluidos,
/// límites, beneficios, reglas de uso, renovación, segmentos, restricciones,
/// métricas y automatizaciones. Nunca columnas por caso.
model MembershipPlan {
  id           String                @id @default(cuid())
  companyId    String
  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  tipo         MembershipPlanType
  precio       Decimal               @db.Decimal(10, 2)
  moneda       String                @default("DOP")
  periodicidad MembershipPeriodicity @default(MONTHLY)
  duracionDias Int? // null = ligado a periodicidad
  creditos     Int? // para CREDITS/HYBRID (null = no aplica)
  ilimitado    Boolean               @default(false) // para UNLIMITED/tiers unlimited
  templateKey  String? // plantilla de industria de la que nació (ej. "carwash.unlimited")
  config       Json                  @default("{}") // configuración flexible (ver dominio)
  status       String                @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  version      Int                   @default(1)
  metadata     Json                  @default("{}")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  instances MembershipInstance[]

  @@index([companyId, tipo])
  @@index([companyId, status])
  @@map("membership_plans")
}

/// Membresía de un suscriptor (cliente, familia, empresa/flota…). El suscriptor
/// se referencia de forma genérica (`subscriberId`/`subscriberKind`) para no
/// acoplar el motor a una entidad concreta.
model MembershipInstance {
  id                String                   @id @default(cuid())
  companyId         String
  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId            String
  plan              MembershipPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriberId      String // ref. genérica al titular
  subscriberKind    String                   @default("CLIENT") // CLIENT | COMPANY | USER
  status            MembershipInstanceStatus @default(PENDING)
  inicioEn          DateTime?
  finEn             DateTime?
  renuevaEn         DateTime?
  autoRenovar       Boolean                  @default(false)
  creditosRestantes Int?
  vehiculos         Json                     @default("[]") // family/fleet: lista de vehículos
  config            Json                     @default("{}") // overrides/snapshot
  metadata          Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  usage MembershipUsage[]

  @@index([companyId, status])
  @@index([planId])
  @@index([subscriberId])
  @@map("membership_instances")
}

/// Registro de uso (Usage Tracking): cada consumo de un servicio/beneficio.
model MembershipUsage {
  id         String             @id @default(cuid())
  companyId  String // scalar (sin relación) para filtrar por empresa
  instanceId String
  instance   MembershipInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  servicio   String // ej. "lavado_exterior", "detailing"
  cantidad   Int                @default(1)
  vehiculo   String? // placa/id de vehículo cuando aplica
  usadoEn    DateTime           @default(now())
  meta       Json               @default("{}")

  @@index([instanceId, usadoEn])
  @@index([companyId, usadoEn])
  @@map("membership_usage")
}

// ─────────────────────────────────────────────
// FASE C · BENEFIT ENGINE (Benefits & Rewards Library)
// Un beneficio es una ENTIDAD independiente y editable que cualquier módulo
// (membresías, promociones, referidos, puntos, gamificación, campañas,
// automatizaciones) puede seleccionar, modificar o crear. Todo lo específico
// vive en `config` (JSON): valor, servicio, reglas, restricciones,
// disponibilidad y módulos donde puede usarse. Ningún flujo existente lo
// consume todavía.
// ─────────────────────────────────────────────

/// Los 10 tipos base de beneficio (el detalle —% vs monto, servicio, etc.—
/// vive en `config`). CUSTOM habilita beneficios creados por la empresa.
enum BenefitType {
  SERVICE_FREE // servicio gratis (lavado, aspirado, cera…)
  DISCOUNT // descuento (% o monto fijo, según config)
  UPGRADE // mejora de servicio (básico→premium)
  PRODUCT // producto físico
  POINTS // puntos de lealtad
  CREDIT // crédito/saldo interno (wallet)
  TIME // tiempo (mes gratis, visita extra, precio congelado)
  EXPERIENCE // experiencia (evento, servicio personalizado)
  ACCESS // acceso exclusivo (línea rápida, área VIP)
  CUSTOM // beneficio personalizado de la empresa
}

/// Estado de un beneficio entregado a un suscriptor (ciclo de canje).
enum BenefitGrantStatus {
  GRANTED // entregado, disponible para canjear
  REDEEMED // canjeado/utilizado
  EXPIRED // venció sin usarse
  REVOKED // revocado por la empresa
}

/// Catálogo de beneficios de una empresa (plantilla instanciada o creado a
/// mano). Reutilizable por todos los módulos. `costoReal` vs `valorPercibido`
/// permiten calcular rentabilidad/ROI.
model Benefit {
  id             String      @id @default(cuid())
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code           String? // ej. "CAR-001" cuando nace de una plantilla
  nombre         String
  descripcion    String?
  categoria      String // categoría de la biblioteca (SERVICE, DISCOUNT, VIP…)
  tipo           BenefitType
  valorPercibido Decimal?    @db.Decimal(10, 2) // lo que el cliente cree que vale
  costoReal      Decimal?    @db.Decimal(10, 2) // lo que le cuesta al negocio
  templateKey    String? // plantilla de industria de la que nació
  config         Json        @default("{}") // valor, servicio, reglas, restricciones, disponibilidad, módulos
  status         String      @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  grants                  BenefitGrant[]
  // Benefit Transformation Engine (Fase E1.7). Relaciones inversas.
  transformationsAsSource BenefitTransformation[] @relation("TransformationSource")
  transformationsAsTarget BenefitTransformation[] @relation("TransformationTarget")

  @@index([companyId, status])
  @@index([companyId, categoria])
  @@index([companyId, tipo])
  @@map("benefits")
}

/// Beneficio entregado a un suscriptor desde un módulo concreto. Es la fuente
/// de las métricas del Benefit Engine (entregados, utilizados, costo real, ROI).
model BenefitGrant {
  id             String             @id @default(cuid())
  companyId      String // scalar (sin relación) para filtrar por empresa
  benefitId      String
  benefit        Benefit            @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  subscriberId   String // ref. genérica al titular (cliente/usuario/empresa)
  subscriberKind String             @default("CLIENT")
  sourceModule   String // membership | promotion | referral | points | gamification | campaign | automation
  status         BenefitGrantStatus @default(GRANTED)
  grantedAt      DateTime           @default(now())
  redeemedAt     DateTime?
  expiresAt      DateTime?
  meta           Json               @default("{}")

  @@index([companyId, status])
  @@index([benefitId, status])
  @@index([subscriberId])
  @@index([companyId, sourceModule])
  @@map("benefit_grants")
}

// ─────────────────────────────────────────────
// FASE E1.7 · BENEFIT TRANSFORMATION ENGINE
// Motor universal de transformación de beneficios: upgrade, downgrade, exchange,
// replacement, customization, split, merge. Historial inmutable, resolución
// automática de fondeo (puntos, créditos, cupones, promociones, pago) y
// políticas configurables por empresa. Sin lógica de industria.
// ─────────────────────────────────────────────

enum TransformationType {
  UPGRADE // mejora (básico → premium)
  DOWNGRADE // rebaja (premium → básico)
  EXCHANGE // intercambio (A → B + C)
  REPLACEMENT // reemplazo autorizado
  CUSTOMIZATION // personalización antes de consumir
  SPLIT // dividir un beneficio en varios (arquitectura preparada)
  MERGE // combinar varios en uno (arquitectura preparada)
}

enum TransformationStatus {
  REQUESTED // cliente lo solicitó
  RESOLVING // calculando mejor forma de fondear
  RESOLVED // resolución encontrada, esperando acción
  PENDING_APPROVAL // requiere aprobación administrativa
  APPROVED // aprobado, pendiente de ejecución/pago
  PENDING_PAYMENT // esperando pago de diferencia
  EXECUTING // ejecutando la transformación
  COMPLETED // completada exitosamente
  REJECTED // rechazada por admin
  CANCELLED // cancelada por cliente
  FAILED // falló durante ejecución
}

/// Registro inmutable de una transformación de beneficio. Cada operación genera
/// un registro independiente: nunca se sobrescribe el beneficio original.
model BenefitTransformation {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriberId   String
  subscriberKind String               @default("CLIENT")
  type           TransformationType
  status         TransformationStatus @default(REQUESTED)

  // Beneficio origen
  sourceBenefitId String
  sourceBenefit   Benefit @relation("TransformationSource", fields: [sourceBenefitId], references: [id])
  sourceGrantId   String?

  // Beneficio destino (null hasta que se resuelva)
  targetBenefitId String?
  targetBenefit   Benefit? @relation("TransformationTarget", fields: [targetBenefitId], references: [id])
  targetGrantId   String?

  // Economía
  sourceValue      Decimal? @db.Decimal(10, 2)
  targetValue      Decimal? @db.Decimal(10, 2)
  differenceAmount Decimal? @db.Decimal(10, 2) // diferencia bruta
  resolvedAmount   Decimal? @db.Decimal(10, 2) // monto final tras aplicar fondeos

  // Resolución: detalle de qué fuentes se usaron (puntos, créditos, promos…)
  resolution       Json      @default("{}")
  // Política que autorizó la transformación
  policyId         String?
  requiresApproval Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?
  rejectionReason  String?

  // Contexto
  sucursalId    String?
  requestedById String?
  config        Json    @default("{}")
  metadata      Json    @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([companyId, status])
  @@index([companyId, type])
  @@index([subscriberId])
  @@index([sourceBenefitId])
  @@index([targetBenefitId])
  @@map("benefit_transformations")
}

/// Política de transformación configurable por empresa. Define qué
/// transformaciones están permitidas, con qué restricciones y métodos de fondeo.
model TransformationPolicy {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  tipo        TransformationType
  activa      Boolean            @default(true)
  prioridad   Int                @default(0)
  config      Json               @default("{}") // TransformationPolicyConfig
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([companyId, tipo, activa])
  @@map("transformation_policies")
}

// ─────────────────────────────────────────────
// FASE D · REFERRAL ENGINE (Referral Strategy Library)
// Motor universal de programas de recomendación 100% configurables. Reutiliza
// el Benefit Engine (Fase C) para las recompensas, sin duplicar lógica. Todo lo
// específico (reglas, recompensas, escalado, límites, condiciones, segmentos,
// estados, tipos de enlace, antifraude, métricas) vive en `config` (JSON).
// Coexiste con el sistema de referidos EN VIVO (Referido/ReferralEvent) sin
// tocarlo. Ningún flujo existente consume estas tablas todavía.
// ─────────────────────────────────────────────

/// Los 10 modelos de programa de referidos del Documento Maestro 4.
enum ReferralModel {
  CLASSIC // ambos participan; negocios pequeños
  REFERRER_ONLY // solo gana quien invita
  REFERRED_ONLY // solo gana el nuevo cliente (captación)
  BOTH // ambos ganan (el más usado)
  PROGRESSIVE // recompensa escalonada por cantidad de referidos
  AMBASSADOR // embajadores con beneficios permanentes
  INFLUENCER // alcance; no requiere compras frecuentes
  CORPORATE // una empresa recomienda a otra
  EMPLOYEE // empleados generan clientes
  TEAM // sucursales/equipos compiten
}

/// Estado de un participante (quien invita) dentro de un programa.
enum ReferralParticipantStatus {
  ACTIVE
  PAUSED
  BLOCKED
}

/// Programa de referidos configurable de una empresa. `type` fija el modelo;
/// el resto de la estrategia vive en `config`.
model ReferralProgram {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre      String
  objetivo    String? // captación, retención, alcance, corporativo…
  type        ReferralModel
  templateKey String? // plantilla de industria de la que nació
  config      Json          @default("{}") // reglas, recompensas, escalado, límites, condiciones, segmentos, estados, enlaces, antifraude, métricas
  status      String        @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  participants ReferralParticipant[]
  referrals    ReferralReferral[]

  @@index([companyId, status])
  @@index([companyId, type])
  @@map("referral_programs")
}

/// Un participante inscrito en un programa (quien invita): su código/enlace,
/// contadores y nivel de escalado. El titular se referencia de forma genérica.
model ReferralParticipant {
  id             String                    @id @default(cuid())
  companyId      String
  programId      String
  program        ReferralProgram           @relation(fields: [programId], references: [id], onDelete: Cascade)
  referrerId     String // ref. genérica (cliente/usuario/empresa/sucursal)
  referrerKind   String                    @default("CLIENT")
  code           String // código único del participante dentro del programa
  status         ReferralParticipantStatus @default(ACTIVE)
  level          Int                       @default(0) // nivel de escalado alcanzado
  referralsCount Int                       @default(0) // referidos registrados
  convertedCount Int                       @default(0) // referidos que convirtieron
  metadata       Json                      @default("{}")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  referrals ReferralReferral[]

  @@unique([programId, code])
  @@index([companyId, programId])
  @@index([referrerId])
  @@map("referral_participants")
}

/// Un referido concreto y su recorrido por el flujo configurable de estados.
/// La recompensa se libera en el estado que la empresa decida (config.rewardState).
model ReferralReferral {
  id             String              @id @default(cuid())
  companyId      String
  programId      String
  program        ReferralProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  participantId  String
  participant    ReferralParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  referredId     String? // ref. genérica al invitado (null hasta que se registra)
  referredKind   String              @default("CLIENT")
  state          String              @default("INVITED") // estado actual del flujo configurable
  history        Json                @default("[]") // [{state, at}] recorrido
  suspicious     Boolean             @default(false) // antifraude
  fraudReasons   Json                @default("[]") // códigos de reglas disparadas
  rewardReleased Boolean             @default(false)
  rewardGrantId  String? // id del BenefitGrant liberado (Fase C)
  invitedAt      DateTime            @default(now())
  meta           Json                @default("{}")

  @@index([companyId, programId, state])
  @@index([participantId, state])
  @@index([referredId])
  @@map("referral_referrals")
}

// ─────────────────────────────────────────────
// FASE E1 · AUTOMATION ENGINE (Automation Strategy Library)
// Motor UNIVERSAL de automatizaciones. Una automatización nunca contiene lógica
// fija: se compone de piezas reutilizables (trigger + condiciones + acciones +
// esperas + variables + eventos). Reutiliza OBLIGATORIAMENTE el Rule Engine
// (decisiones) y el Action Engine (acciones); no ejecuta nada por su cuenta.
// Toda la estrategia vive en `config` (JSON). Multi-tenant por companyId.
// Ningún flujo de la app consume estas tablas todavía.
// ─────────────────────────────────────────────

/// Estado de una ejecución (run) de automatización.
enum AutomationRunStatus {
  RUNNING
  WAITING // pausada en una espera (se reanuda luego)
  SUCCESS
  FAILED
  SKIPPED // no aplicaba (horario/límite/condición inicial)
}

/// Una automatización configurable de una empresa. Trigger + pasos (condiciones
/// + acciones + esperas) + límites/horarios/canales viven en `config`. Puede
/// nacer de una plantilla (`templateKey`) y encadenar otras automatizaciones.
model Automation {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  objetivo     String? // captación, onboarding, frecuencia, recuperación…
  templateKey  String? // plantilla universal de la que nació
  /// Tipo de disparador (EVENT | SCHEDULE | SEGMENT_ENTER | DATE | MANUAL…).
  triggerType  String
  /// Para EVENT: tipo de evento que la dispara (ej. "cliente.visita").
  triggerEvent String?
  config       Json     @default("{}") // trigger, pasos, variables, límites, horarios, días, canales, encadenado, prioridad
  status       String   @default("DRAFT") // DRAFT | PUBLISHED | PAUSED | ARCHIVED
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  runs AutomationRun[]

  @@index([companyId, status])
  @@index([companyId, triggerType])
  @@index([companyId, triggerEvent])
  @@map("automations")
}

/// Registro/auditoría de una ejecución: hora, trigger, reglas evaluadas,
/// acciones ejecutadas, resultado, errores y tiempo. Toda ejecución auditable.
model AutomationRun {
  id             String              @id @default(cuid())
  companyId      String
  automationId   String
  automation     Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status         AutomationRunStatus @default(RUNNING)
  /// Sujeto impactado (cliente/usuario/empresa), ref. genérica.
  subjectId      String?
  subjectKind    String?
  triggeredBy    String? // trigger/evento que la originó
  rulesEvaluated Json                @default("[]") // [{expr, passed}]
  actionsRun     Json                @default("[]") // [{type, ok, detail}]
  result         Json                @default("{}")
  error          String?
  durationMs     Int?
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  meta           Json                @default("{}")

  @@index([companyId, automationId, status])
  @@index([companyId, startedAt])
  @@index([subjectId])
  @@map("automation_runs")
}

/// Bus de eventos: toda acción importante genera un evento que otras
/// automatizaciones pueden consumir (encadenado). `processed` evita reprocesar.
model AutomationEvent {
  id          String   @id @default(cuid())
  companyId   String
  type        String // ej. "cliente.registrado", "cliente.visita", "cliente.subio_nivel"
  subjectId   String?
  subjectKind String?  @default("CLIENT")
  payload     Json     @default("{}")
  source      String? // automationId/módulo que lo emitió
  processed   Boolean  @default(false)
  occurredAt  DateTime @default(now())

  @@index([companyId, type, processed])
  @@index([companyId, occurredAt])
  @@index([subjectId])
  @@map("automation_events")
}

// ─────────────────────────────────────────────
// FASE E4 · TRANSACTION & RECEIPT ENGINE
// Toda operación (redención de membresía, promoción, beneficio, recompensa,
// cupón, puntos, referido, venta futura…) genera una TRANSACCIÓN oficial con
// ID único (TX-YYYYMMDD-NNNNNN), estados con historial de transiciones,
// auditoría completa y comprobante reimprimible. Universal: sin lógica de
// industria (la especificidad vive en snapshot/config JSON y plantillas).
// ─────────────────────────────────────────────

enum TransactionTipo {
  MEMBERSHIP_REDEMPTION // uso de membresía (visita)
  PROMOTION_USE
  BENEFIT_USE
  REWARD_REDEMPTION
  COUPON_USE
  POINTS_SPEND
  REFERRAL
  SALE // ventas futuras
  PURCHASE // compras futuras
  OTHER
}

enum TransactionEstado {
  PENDING
  VALIDATING
  APPROVED
  APPLIED
  CANCELLED
  REVERTED
  EXPIRED
  ERROR
}

model Transaction {
  id           String            @id @default(cuid())
  /// ID oficial único e irrepetible: TX-YYYYMMDD-NNNNNN. Se imprime en el
  /// ticket, se codifica en el QR de la transacción y sirve para consultas.
  codigo       String            @unique
  /// Número de ticket secuencial por empresa (TCK-000123).
  ticketNumero String
  tipo         TransactionTipo
  estado       TransactionEstado @default(PENDING)

  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sucursalId String?
  sucursal   Sucursal? @relation(fields: [sucursalId], references: [id])
  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id])
  empleadoId String?
  empleado   User?     @relation("TransactionEmpleado", fields: [empleadoId], references: [id])
  /// Caja/terminal (texto libre hasta que exista gestión de cajas).
  caja       String?

  membershipId   String?
  membership     Membership? @relation(fields: [membershipId], references: [id])
  visitId        String?     @unique
  visit          Visit?      @relation(fields: [visitId], references: [id])
  /// QR de un solo uso que se consumió para crear esta transacción: permite
  /// que re-escanear un QR usado muestre el historial completo de la operación.
  qrTokenUsadoId String?     @unique
  qrTokenUsado   QrToken?    @relation("TransactionQrUsado", fields: [qrTokenUsadoId], references: [id])

  /// Etiquetas congeladas al momento de la operación (cliente, vehículo,
  /// servicio, promoción, beneficio, membresía, plan, empleado, sucursal…):
  /// el historial no cambia aunque cambien los datos maestros.
  snapshot     Json    @default("{}")
  /// Auditoría técnica: ip, userAgent, dispositivo, navegador.
  auditoria    Json    @default("{}")
  /// Resultado legible u observaciones del operador.
  resultado    String?
  errorDetalle String?
  /// Duración de la operación (ms) para métricas de tiempo de atención.
  executionMs  Int?

  createdAt   DateTime  @default(now())
  appliedAt   DateTime?
  cancelledAt DateTime?
  revertedAt  DateTime?

  transiciones TransactionTransicion[]
  impresiones  ReceiptImpresion[]

  @@index([companyId, estado])
  @@index([companyId, createdAt])
  @@index([clienteId, createdAt])
  @@index([empleadoId])
  @@map("transactions")
}

/// Historial inmutable de cambios de estado de una transacción.
model TransactionTransicion {
  id            String             @id @default(cuid())
  transactionId String
  transaction   Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  desde         TransactionEstado?
  hacia         TransactionEstado
  motivo        String?
  userId        String?
  user          User?              @relation(fields: [userId], references: [id])
  createdAt     DateTime           @default(now())

  @@index([transactionId, createdAt])
  @@map("transaction_transitions")
}

/// Contadores atómicos para IDs secuenciales (TX por día, ticket por empresa).
/// id = scope, ej. "TX:20260711" o "TICKET:companyId". Se incrementa con
/// INSERT ... ON CONFLICT DO UPDATE ... RETURNING (una sola sentencia atómica).
model TransactionCounter {
  id  String @id
  seq Int    @default(0)

  @@map("transaction_counters")
}

/// Cada impresión/reimpresión de comprobante queda auditada.
model ReceiptImpresion {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  empleadoId    String?
  empleado      User?       @relation(fields: [empleadoId], references: [id])
  /// false = impresión original; true = COPIA.
  esCopia       Boolean     @default(false)
  /// Nº de impresión de esta transacción (1 = original, 2+ = copias).
  numero        Int
  motivo        String?
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@map("receipt_prints")
}

/// Plantilla de comprobante por empresa (Receipt Engine): personalización de
/// encabezado, pie, bloques, campos opcionales y ancho de papel SIN tocar
/// código. `config` sigue el contrato ReceiptTemplateConfig de src/lib/receipts.
model ReceiptTemplate {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("receipt_templates")
}
