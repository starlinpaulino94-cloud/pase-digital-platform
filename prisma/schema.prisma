generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// ENUMS
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum AppRole {
  SUPERADMIN
  ADMIN_EMPRESA // legacy: admin de empresa (se mantiene por usuarios existentes)
  EMPLEADO
  CLIENTE
  // Roles de equipo de empresa (deben coincidir con AppRole en src/types).
  ADMINISTRADOR
  GERENTE
  CAJERO
  RECEPCION
  MARKETING // difusiГіn: promociones, campaГ±as, publicaciones, audiencia, notificaciones
  SUPERVISOR // operaciГіn: dashboard/reportes, clientes, validar pagos, scanner
}

enum NotifTipo {
  PAGO_APROBADO
  PAGO_RECHAZADO
  NUEVO_COMPROBANTE
  MEMBRESIA_POR_VENCER
  MEMBRESIA_ACTIVADA
  PROMOCION_NUEVA
  RECOMPENSA_REFERIDO
  SISTEMA
  TICKET_NUEVO
  TICKET_RESPUESTA
  TICKET_ACTUALIZADO
}

enum TicketEstado {
  NUEVO
  EN_PROCESO
  ESPERANDO_CLIENTE
  RESUELTO
  CERRADO
}

enum TicketCategoria {
  PAGO
  MEMBRESIA
  BENEFICIOS
  APP
  OTRO
}

enum TicketAutor {
  CLIENTE
  ADMIN
  SISTEMA
}

enum MembershipEstado {
  PENDIENTE // solicitada, sin pago
  PENDIENTE_PAGO // comprobante enviado, esperando validaciГіn
  RECHAZADA // pago rechazado por admin
  ACTIVA
  VENCIDA
  CANCELADA
}

enum MetodoPagoTipo {
  TRANSFERENCIA
  PRESENCIAL
}

enum InvitacionEstado {
  PENDIENTE
  ACEPTADA
  CANCELADA
  EXPIRADA
}

enum AuditAccion {
  VISITA_CONFIRMADA
  PAGO_APROBADO
  PAGO_RECHAZADO
  MEMBRESIA_CANCELADA
  MEMBRESIA_RENOVADA
  QR_GENERADO
  QR_USADO
  QR_COMPARTIDO
  CAJA_ABIERTA
  CAJA_CERRADA
  COBRO_REGISTRADO
  COMPROBANTE_IMPRESO
  REFERIDO_COMPLETADO
  RECOMPENSA_OTORGADA
  NOTA_INTERNA
  PLANTILLA_RECIBO_ACTUALIZADA
  CUENTA_ELIMINADA
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// MODELS
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model User {
  id                 String    @id @default(cuid())
  supabaseId         String    @unique
  email              String    @unique
  name               String
  role               AppRole   @default(CLIENTE)
  companyId          String?
  company            Company?  @relation(fields: [companyId], references: [id])
  // Consentimiento (cumplimiento): rastro auditable de aceptaciГіn de tГ©rminos
  // y opt-in de comunicaciones de marketing, con la versiГіn y el momento.
  termsAcceptedAt    DateTime?
  termsVersion       String?
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  memberships     Membership[]
  visits          Visit[]             @relation("EmpleadoVisits")
  auditLogs       AuditLog[]
  comprobantes    Comprobante[]
  notificaciones  Notificacion[]
  follows         CompanyFollow[]
  promosGuardadas PromocionGuardada[]
  notasCliente    ClienteNota[]
  intereses       UserInteres[]
  empresasAcceso  UserCompanyAccess[]

  // Listados de empleados por empresa (/admin/empleados) y conteos por empresa.
  transaccionesComoEmpleado Transaction[]              @relation("TransactionEmpleado")
  cajasAbiertas             CajaSesion[]               @relation("CajaAbiertaPor")
  cajasCerradas             CajaSesion[]               @relation("CajaCerradaPor")
  transicionesTransaccion   TransactionTransicion[]
  impresionesRecibo         ReceiptImpresion[]
  comprasAprobadas          ProductoCompra[]           @relation("CompraAprobadaPor")
  transicionesCompra        ProductoCompraTransicion[]

  @@index([companyId])
  @@map("users")
}

/// Acceso multi-empresa para usuarios de staff: un mismo administrador puede
/// gestionar VARIAS empresas. `User.companyId` sigue siendo la empresa ACTIVA
/// (la que ve en su panel); esta tabla define a cuГЎles puede cambiar.
model UserCompanyAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("user_company_access")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        String // "carwash" | "restaurante"
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  email     String?
  telefono  String?
  direccion String?
  ciudad    String?
  categoria String?
  website   String?

  // FASE 2: Marketplace fields
  isPublished           Boolean  @default(true)
  isFeatured            Boolean  @default(false)
  featuredOrder         Int?
  bannerUrl             String?
  galleryImages         String[] @default([])
  provincia             String?
  pais                  String?
  // F5/Onboarding: datos legales y de ubicaciГіn precisa (paso 2-3 del wizard).
  razonSocial           String?
  codigoPostal          String?
  latitud               Float?
  longitud              Float?
  zonaCobertura         String? // texto libre: barrios/zonas atendidas o radio
  // F5/Onboarding paso 4: configuraciГіn regional y de marca. Preferencia por
  // empresa aplicada al FORMATEAR (moneda/fecha); no traduce la UI ni convierte
  // divisas (DecisiГіn 4 del plan de onboarding).
  moneda                String   @default("DOP") // ISO 4217: DOP, USD, EURвЂ¦
  zonaHoraria           String   @default("America/Santo_Domingo") // IANA
  idioma                String   @default("es-DO") // locale BCP 47
  // Fase E7: mГ©todo de escaneo predeterminado del escГЎner ("camara" | "lector").
  // El operador puede cambiarlo en pantalla sin recargar; esto es solo el valor
  // inicial que la empresa configura.
  escanerModo           String   @default("camara")
  colorPrimario         String? // hex de marca, ej. "#0ea5e9"
  // Engagement Engine В· Fase 7: personalizaciГіn del motor por empresa.
  // JSON: { color?, gamificacion?, pruebaSocial?, campanas?, carruseles? }.
  // Ausente/null = todo activado y color = colorPrimario.
  engagementConfig      Json?
  politicaCancelacion   String?
  politicaPrivacidad    String?
  terminosEmpresa       String?
  whatsapp              String?
  instagram             String?
  facebook              String?
  tiktok                String?
  googleMapsUrl         String?
  // F4.1: horario de atenciГіn mostrado en el perfil pГєblico (texto libre,
  // ej. "Lun-Vie 8:00-18:00 В· SГЎb 9:00-14:00").
  horario               String?
  totalMembersCount     Int      @default(0)
  activePromotionsCount Int      @default(0)
  averageRating         Decimal? @db.Decimal(3, 2)

  // O-13: beneficio de bienvenida financiado por la EMPRESA (opt-in). Se
  // aplica UNA sola vez, en la primera activaciГіn de membresГ­a del cliente
  // en esta empresa. PORCENTAJE = % sobre el precio del plan; MONTO = importe
  // fijo (nunca supera el precio del plan).
  bienvenidaActiva Boolean  @default(false)
  bienvenidaTipo   String   @default("PORCENTAJE") // PORCENTAJE | MONTO
  bienvenidaValor  Decimal? @db.Decimal(10, 2)

  users                  User[]
  plans                  Plan[]
  clientes               Cliente[]
  memberships            Membership[]
  sucursales             Sucursal[]
  cajaSesiones           CajaSesion[]
  metodosPago            MetodoPago[]
  auditLogs              AuditLog[]
  promociones            Promocion[]
  referidos              Referido[]
  reglasRecompensa       ReglaRecompensa[]
  whatsappConfig         WhatsAppConfig?
  faqs                   FaqItem[]
  tickets                SupportTicket[]
  categories             CompanyToCategory[]
  ratings                CompanyRating[]
  referralEvents         ReferralEvent[]
  followers              CompanyFollow[]
  posts                  CompanyPost[]
  campanas               Campana[]
  invitaciones           Invitacion[]
  accesosStaff           UserCompanyAccess[]
  // Benefit Engine (Fase C). Relaciones inversas; ningГєn flujo las consume aГєn.
  benefits               Benefit[]
  // Referral Engine (Fase D). Relaciones inversas; ningГєn flujo las consume aГєn.
  referralPrograms       ReferralProgram[]
  // Automation Engine (Fase E1). Relaciones inversas; ningГєn flujo las consume aГєn.
  automations            Automation[]
  // Motor Universal de Reglas (Fase 1). Relaciones inversas; no cambian el
  // comportamiento actual: ninguna funciГіn existente las consulta todavГ­a.
  ruleGroups             RuleGroup[]
  rules                  Rule[]
  ruleExecLogs           RuleExecutionLog[]
  // Framework Universal de Promociones (Fase 4). Relaciones inversas; ningГєn
  // flujo existente las consulta.
  promotions             Promotion[]
  promotionAudits        PromotionAudit[]
  // Business Data Dictionary (Fase 6). Variables especГ­ficas de empresa.
  dictionaryVariables    DataDictionaryVariable[]
  // Membership Engine universal (Fase A). Independiente del modelo Membership
  // legacy (Car Wash). NingГєn flujo existente lo consulta.
  membershipPlans        MembershipPlan[]
  membershipInstances    MembershipInstance[]
  // Benefit Transformation Engine (Fase E1.7).
  benefitTransformations BenefitTransformation[]
  transformationPolicies TransformationPolicy[]

  transacciones   Transaction[]
  receiptTemplate ReceiptTemplate?
  compras         ProductoCompra[]
  // Growth Engine: CampaГ±as de InvitaciГіn ("Invita y Gana").
  campanasInvitacion CampanaInvitacion[]

  // Growth Engine 3.0 (sistema viral de referidos).
  growthLinks  GrowthLink[]
  growthConfig GrowthConfig?
  growthRules  GrowthRule[]

  // Engagement Engine В· Fase 2 (Motor de CampaГ±as de marketing).
  marketingCampaigns MarketingCampaign[]
  // Engagement Engine В· Fase 6B (Ruleta de premios).
  ruletaPremios      RuletaPremio[]
  ruletaJugadas      RuletaJugada[]

  @@index([isPublished, isFeatured])
  @@index([ciudad, provincia])
  @@index([type])
  @@index([createdAt])
  @@map("companies")
}

// Sucursales fГ­sicas de una empresa
model Sucursal {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  nombre    String
  direccion String?
  telefono  String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  visits Visit[]

  transacciones Transaction[]

  cajaSesiones    CajaSesion[]
  membershipsPago Membership[]     @relation("MembershipSucursalPago")
  comprasPago     ProductoCompra[] @relation("CompraSucursalPago")

  @@index([companyId])
  @@map("sucursales")
}

// в”Ђв”Ђв”Ђ Caja (POS) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum CajaSesionEstado {
  ABIERTA
  CERRADA
}

/// Forma en que se recibiГі un cobro presencial. OTRO deja la puerta abierta a
/// tarjetas/pasarelas futuras sin tocar el enum de nuevo.
enum MetodoCobroTipo {
  EFECTIVO
  TRANSFERENCIA
  OTRO
}

/// SesiГіn de caja de una sucursal (turno): apertura в†’ cobros в†’ cierre con
/// arqueo. No se permite cobrar sin una sesiГіn ABIERTA en la sucursal. El
/// registro es permanente: nunca se elimina, solo se cierra.
model CajaSesion {
  id         String           @id @default(cuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sucursalId String
  sucursal   Sucursal         @relation(fields: [sucursalId], references: [id])
  estado     CajaSesionEstado @default(ABIERTA)

  /// Responsable del turno (quien abre la caja).
  abiertaPorId String
  abiertaPor   User    @relation("CajaAbiertaPor", fields: [abiertaPorId], references: [id])
  cerradaPorId String?
  cerradaPor   User?   @relation("CajaCerradaPor", fields: [cerradaPorId], references: [id])
  /// Turno legible ("MaГ±ana", "Tarde", "Noche") вЂ” opcional.
  turno        String?

  balanceInicial Decimal @default(0) @db.Decimal(10, 2)
  /// Efectivo contado al cerrar.
  balanceFinal    Decimal? @db.Decimal(10, 2)
  /// Congelado al cerrar: inicial + cobros en EFECTIVO de la sesiГіn.
  balanceEsperado Decimal? @db.Decimal(10, 2)
  /// Congelada al cerrar: final в€’ esperado (faltante/sobrante).
  diferencia      Decimal? @db.Decimal(10, 2)
  observaciones   String?

  abiertaAt DateTime  @default(now())
  cerradaAt DateTime?

  cobros Transaction[]

  @@index([sucursalId, estado])
  @@index([companyId, abiertaAt])
  @@map("caja_sesiones")
}

// MГ©todos de pago configurables por empresa (sin tocar cГіdigo)
model MetodoPago {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  tipo          MetodoPagoTipo
  nombre        String // "Banco Popular", "Pago en sucursal"
  titular       String?
  numeroCuenta  String?
  tipoCuenta    String? // "Ahorro", "Corriente"
  instrucciones String? // texto libre para mostrar al cliente
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships Membership[]
  compras     ProductoCompra[]

  @@index([companyId])
  @@map("metodos_pago")
}

// FASE E8 В· Tipo de Beneficio Digital. Concepto unificado: promociones,
// membresГ­as, cupones, bonos, gift cards y entradas comparten el mismo ciclo
// (adquirir в†’ QR в†’ canjear). AГ±adir un tipo nuevo NO requiere rediseГ±ar.
enum BeneficioTipo {
  PROMOTION
  MEMBERSHIP
  COUPON
  VOUCHER
  GIFT
  EVENT
}

// Promociones publicadas por una empresa, visibles para sus clientes
// (incluyendo clientes afiliados a varias empresas, vГ­a Cliente.companyId).
model Promocion {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  titulo        String
  descripcion   String
  imagenUrl     String?
  vigenciaDesde DateTime  @default(now())
  vigenciaHasta DateTime?
  activo        Boolean   @default(true)
  publicadaEn   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // FASE 2: Marketplace fields
  slug          String?
  tipo          String   @default("general") // ver PROMO_TIPOS en src/lib/promociones.ts
  descuento     Int? // % o monto fijo segГєn tipo
  codigo        String? // CГіdigo cupГіn
  isFeatured    Boolean  @default(false)
  featuredOrder Int?
  viewCount     Int      @default(0)
  shareCount    Int      @default(0)
  tags          String[] @default([])

  // F4.2: Promociones 2.0
  visibilidad String   @default("publica") // "publica" (todo MembeGo) | "privada" (solo miembros)
  maxCanjes   Int? // lГ­mite de canjes (null = ilimitado)
  campanaId   String?
  campana     Campana? @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  canjes      Int      @default(0)
  prioridad   Int      @default(0) // mayor = primero en los listados
  archivada   Boolean  @default(false)

  // FASE E5: la promociГіn como producto comercial comprable.
  // - Ventana de adquisiciГіn = vigenciaDesde/vigenciaHasta (ya existentes).
  // - Vigencia del beneficio: dГ­as desde la activaciГіn O fecha fija; ambos
  //   null = sin vencimiento. El Rule Engine valida ambas ventanas.
  esComprable            Boolean       @default(false)
  precio                 Decimal?      @db.Decimal(10, 2) // 0 = gratis (activaciГіn directa)
  usosPorCompra          Int           @default(1)
  // CuГЎntas veces puede un mismo cliente adquirir esta promociГіn en total.
  // null = sin lГ­mite. 1 = un solo uso por cliente (ej: "primer lavado gratis").
  // Cuenta toda adquisiciГіn entregada (activa, usada o vencida), no solo las
  // vivas: una vez consumida, no se puede volver a adquirir.
  limitePorCliente       Int?
  beneficioVigenciaDias  Int?
  beneficioVigenciaHasta DateTime?
  // Restricciones de consumo (0=domingo вЂ¦ 6=sГЎbado; vacГ­o = todos los dГ­as).
  diasPermitidos         Int[]         @default([])
  horaDesde              String? // "HH:MM"
  horaHasta              String? // "HH:MM"
  // ImГЎgenes subidas al storage del proyecto (galerГ­a futura; [0] = principal).
  imagenes               String[]      @default([])
  // FASE E8 В· Beneficio Digital: toda promociГіn es un beneficio con un TIPO.
  // Hoy se usa PROMOTION; la arquitectura queda lista para cupones, gift cards,
  // bonos y entradas a eventos sin rediseГ±o (solo se aГ±aden reglas del tipo).
  beneficioTipo          BeneficioTipo @default(PROMOTION)

  compras     ProductoCompra[]
  guardadaPor PromocionGuardada[]

  // Growth Engine 3.0: beneficio ofrecido en una landing o entregado por regla.
  growthLinks          GrowthLink[] @relation("GrowthLinkBeneficio")
  growthRulesBeneficio GrowthRule[] @relation("GrowthRuleBeneficio")

  // Engagement Engine В· Fase 6B: promociГіn como premio de la ruleta.
  ruletaPremios RuletaPremio[]

  @@index([companyId, activo])
  @@index([isFeatured, vigenciaHasta])
  @@index([tipo])
  @@index([createdAt])
  // Feed pГєblico de promociones: filtra sin companyId por estado de
  // publicaciГіn; sin este Г­ndice cada carga del feed escanea la tabla.
  @@index([activo, archivada, visibilidad, publicadaEn])
  @@map("promociones")
}

model Plan {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  nombre           String
  precio           Decimal  @db.Decimal(10, 2)
  lavadosIncluidos Int      @default(0)
  esIlimitado      Boolean  @default(false)
  descripcion      String?
  beneficios       String[]
  vigenciaDias     Int      @default(30) // duraciГіn del perГ­odo
  condiciones      String? // texto de condiciones/restricciones
  activo           Boolean  @default(true)
  // F4.3: presentaciГіn del plan en tarjetas pГєblicas y del panel.
  color            String? // hex o token, ej. "#0ea5e9"
  orden            Int      @default(0) // menor = primero
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships            Membership[]
  membershipsSolicitadas Membership[] @relation("PlanSolicitado")

  @@index([companyId])
  @@map("plans")
}

// InvitaciГіn de un miembro al equipo de una empresa (Onboarding Fase 2C).
// El invitado abre el enlace del correo, crea su cuenta y se une con el rol
// asignado. No bloquea la publicaciГіn (el equipo puede armarse mГЎs tarde).
model Invitacion {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  email       String
  rol         AppRole
  token       String           @unique @default(cuid())
  estado      InvitacionEstado @default(PENDIENTE)
  invitadoPor String? // userId de quien invitГі
  expiraEn    DateTime
  aceptadaEn  DateTime?
  createdAt   DateTime         @default(now())

  @@index([companyId, estado])
  @@index([email])
  @@map("invitaciones")
}

model Cliente {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  supabaseId         String
  nombre             String
  telefono           String?
  email              String
  fechaNacimiento    DateTime?
  avatarUrl          String?
  // F5/Onboarding paso 2 (B2C): perfil ampliado del cliente.
  ciudad             String?
  genero             String? // "M" | "F" | "otro" | null (opcional)
  idioma             String? // locale preferido, ej. "es-DO"
  notifPromos        Boolean   @default(true) // recibir promociones
  notifRecordatorios Boolean   @default(true) // recordatorios (vencimiento, etc.)
  codigoReferido     String    @unique @default(cuid())
  // CГіdigo corto legible para el enlace /r/XXXXXX (se genera al visitar el
  // panel de referidos; null hasta entonces).
  codigoCorto        String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  vehiculos       Vehiculo[]
  memberships     Membership[]
  qrTokens        QrToken[] // vacГ­o hasta que tenga membresГ­a activa
  visits          Visit[]
  referidosHechos Referido[]      @relation("Referente")
  referidoComo    Referido[]      @relation("Referido")
  referralEvents  ReferralEvent[] @relation("ReferralEvents")
  tickets         SupportTicket[]
  ratings         CompanyRating[]
  notas           ClienteNota[]

  transacciones Transaction[]
  compras       ProductoCompra[]
  // Growth Engine: progreso y eventos de campaГ±as de invitaciГіn.
  invitacionProgresos InvitacionProgreso[]
  invitacionEventos   InvitacionEvento[]

  // Growth Engine 3.0.
  growthLinks   GrowthLink[]   @relation("GrowthLinks")
  growthRewards GrowthReward[] @relation("GrowthRewards")
  growthWallets GrowthWallet[] @relation("GrowthWallet")

  // Engagement Engine В· Fase 6B (Ruleta de premios).
  ruletaJugadas RuletaJugada[]

  @@unique([supabaseId, companyId])
  // Filtros frecuentes solo por empresa (adminMetrics, reportes, /admin/clientes).
  // El unique (supabaseId, companyId) no cubre bГєsquedas por companyId solo.
  @@index([companyId])
  @@map("clientes")
}

enum ReferidoEstado {
  PENDIENTE
  COMPLETADO
}

enum CondicionRecompensa {
  N_REFERIDOS_COMPLETADOS
}

enum TipoRecompensa {
  LAVADOS_GRATIS
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO
}

// Evento del programa de referidos: cada acciГіn del embudo (compartir, clic,
// registro, membresГ­a) con sus puntos. Base de estadГ­sticas, niveles y ranking.
// DiseГ±ado para extenderse (campaГ±as, afiliados) vГ­a canal/meta sin migrar.
// вљ пёЏ Embudo PARALELO a InvitacionEventoTipo (mismos hitos, otros nombres).
// Equivalencias (ReferralEventTipo в†” InvitacionEventoTipo):
//   SHAREв†”COMPARTIDA В· CLICKв†”ENLACE_ABIERTO В· LANDING_VIEWв†”LANDING_VISTA В·
//   REGISTRO_INICIADOв†”REGISTRO_INICIADO В· REGISTROв†”REGISTRO_COMPLETADO В·
//   MEMBRESIAв†”MEMBRESIA_ADQUIRIDA В· PRIMER_USOв†”PRIMER_CANJE В· RECOMPENSAв†”PREMIO_RECLAMADO.
// Unificarlos en un solo enum es una tarea mayor (migraciГіn de datos en dos
// subsistemas); documentado en docs/GUIA_LENGUAJE_MEMBEGO.md.
enum ReferralEventTipo {
  LINK // Fase E6: enlace de referido generado (cГіdigo corto emitido)
  SHARE // el referente compartiГі su enlace
  CLICK // alguien abriГі /r/[code]
  LANDING_VIEW // Growth Engine 3.0: la landing del referido fue vista
  REGISTRO_INICIADO // Fase E6: landing de registro cargada con atribuciГіn
  REGISTRO // un referido creГі cuenta
  VERIFICADO // Fase E6: el referido confirmГі su correo
  MEMBRESIA // el referido activГі membresГ­a
  COMPRA // Fase E6: primera compra confirmada (membresГ­a o promociГіn E5)
  PRIMER_USO // Growth Engine 3.0: el referido canjeГі su beneficio por 1ВЄ vez
  RECOMPENSA // Fase E6: recompensa entregada al referente
  FRAUDE // Fase E6: intento bloqueado o referido marcado sospechoso
  // Centro global MembeGo: el referido se uniГі a OTRA empresa de la plataforma.
  // companyId = empresa del referente; meta.targetCompanyId = empresa destino.
  REGISTRO_GLOBAL
  MEMBRESIA_GLOBAL
}

model ReferralEvent {
  id                String            @id @default(cuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  clienteId         String // referente dueГ±o del enlace
  cliente           Cliente           @relation("ReferralEvents", fields: [clienteId], references: [id])
  tipo              ReferralEventTipo
  puntos            Int               @default(0)
  canal             String? // native | whatsapp | copy | qr | telegram | ...
  // Fase E6 В· Attribution Tracking: identificador anГіnimo del visitante,
  // sembrado en el clic (cookie) y propagado hasta el registro. Permite
  // visitas ГљNICAS reales y reconstruir el recorrido completo por persona.
  visitorId         String?
  // Fase E6: referido al que pertenece el evento (cuando ya existe cuenta).
  referidoClienteId String?
  // Growth Engine 3.0: enlace de invitaciГіn concreto que originГі el evento.
  growthLinkId      String?
  growthLink        GrowthLink?       @relation(fields: [growthLinkId], references: [id], onDelete: SetNull)
  meta              Json              @default("{}") // dispositivo, campaГ±a, ip hash...
  createdAt         DateTime          @default(now())

  @@index([clienteId, companyId])
  @@index([companyId, tipo, createdAt])
  @@index([companyId, tipo, visitorId])
  @@index([referidoClienteId])
  @@index([growthLinkId, tipo])
  @@map("referral_events")
}

// Referido: vГ­nculo entre quien invita y quien se registrГі con su cГіdigo.
model Referido {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  referenteClienteId String
  referenteCliente   Cliente        @relation("Referente", fields: [referenteClienteId], references: [id])
  referidoClienteId  String         @unique
  referidoCliente    Cliente        @relation("Referido", fields: [referidoClienteId], references: [id])
  estado             ReferidoEstado @default(PENDIENTE)
  recompensaAplicada Boolean        @default(false)
  // Anti-fraude: registro atribuido pero con huella repetida (misma red/
  // dispositivo del referente o de otro referido reciente). Se conserva el
  // vГ­nculo para auditorГ­a, pero NO cuenta en el embudo ni otorga puntos.
  sospechoso         Boolean        @default(false)
  campanaInvitacionId String?
  campanaInvitacion   CampanaInvitacion? @relation(fields: [campanaInvitacionId], references: [id])
  createdAt          DateTime       @default(now())
  completadoEn       DateTime?

  @@index([companyId, referenteClienteId])
  @@index([companyId, sospechoso])
  @@index([campanaInvitacionId])
  @@map("referidos")
}

// Fase E6: recompensa REAL del programa de referidos, con estado propio.
// Reemplaza el booleano recompensaAplicada como fuente de verdad: cada umbral
// alcanzado genera una fila (>= sin pГ©rdidas), auditable y sin doble entrega.
enum ReferralRecompensaEstado {
  PENDIENTE // otorgada pero de entrega manual (descuentos) o esperando entrega
  ENTREGADA // efecto aplicado (p. ej. usos sumados a la membresГ­a)
  RECHAZADA // anulada por el admin (p. ej. fraude posterior)
}

model ReferralRecompensa {
  id                   String                   @id @default(cuid())
  companyId            String
  referenteClienteId   String
  reglaId              String
  regla                ReglaRecompensa          @relation(fields: [reglaId], references: [id])
  estado               ReferralRecompensaEstado @default(PENDIENTE)
  tipo                 TipoRecompensa
  valor                Int
  descripcion          String
  // Umbral de referidos completados que la disparГі (auditorГ­a del cГЎlculo).
  umbral               Int
  completadosAlOtorgar Int
  entregadaAt          DateTime?
  motivoRechazo        String?
  createdAt            DateTime                 @default(now())

  // Una recompensa por regla por referente: el umbral >= no duplica entregas.
  @@unique([referenteClienteId, reglaId])
  @@index([companyId, estado])
  @@index([referenteClienteId])
  @@map("referral_recompensas")
}

// Regla de recompensa 100% configurable desde el panel admin: sin valores
// fijos en cГіdigo. El admin define cuГЎndo y quГ© recompensa otorgar.
model ReglaRecompensa {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  nombre          String
  condicion       CondicionRecompensa
  valorCondicion  Int // ej: 3 referidos completados
  tipoRecompensa  TipoRecompensa
  valorRecompensa Decimal             @db.Decimal(10, 2) // lavados, % o monto segГєn tipo
  activo          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  recompensas ReferralRecompensa[]

  @@index([companyId, activo])
  @@map("reglas_recompensa")
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// GROWTH ENGINE 3.0 В· Sistema viral de referidos
// MГіdulo de crecimiento sobre el motor de eventos EN VIVO (ReferralEvent /
// Referido). Cada enlace compartido es una campaГ±a de adquisiciГіn (GrowthLink)
// con su propia landing, expiraciГіn y embudo. Las recompensas NO estГЎn
// codificadas: reglas configurables por evento (GrowthRule) que se ENTREGAN
// como Beneficios Digitales de E8 (ProductoCompra con QR), puntos o crГ©ditos.
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

/// Disparadores de una regla de recompensa (eventos reales del embudo).
enum GrowthTrigger {
  LINK_ABIERTO // el invitado abriГі la landing / hizo clic
  REGISTRO // el invitado completГі el registro
  VERIFICADO // el invitado verificГі su correo
  MEMBRESIA // el invitado adquiriГі una membresГ­a
  COMPRA // el invitado hizo una compra (promociГіn o plan)
  PRIMER_USO // el invitado canjeГі su beneficio por primera vez
  N_REFERIDOS // umbral de referidos completados (campaГ±as)
}

/// QuГ© recompensa entrega una regla. BENEFICIO usa el Motor de Beneficios
/// Digitales (E8): otorga una PromociГіn como ProductoCompra activo con QR.
enum GrowthRewardTipo {
  PUNTOS
  CREDITOS
  BENEFICIO // Beneficio Digital (PromociГіn E8) entregado como ProductoCompra
  LAVADOS_GRATIS // compat E6: incrementa usos de la membresГ­a activa
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO
}

/// A quiГ©n se le entrega la recompensa de una regla.
enum GrowthBeneficiario {
  REFERENTE // quien invita
  REFERIDO // el invitado
  AMBOS
}

enum GrowthRewardEstado {
  PENDIENTE // otorgada; espera entrega (manual) o activaciГіn del beneficio
  ENTREGADA // efecto aplicado (beneficio activo, puntos/crГ©ditos sumados)
  RECHAZADA // anulada (fraude posterior u otra razГіn)
}

/// Un enlace de invitaciГіn concreto. A diferencia del cГіdigo Гєnico del cliente
/// (legacy), cada GrowthLink tiene su beneficio, expiraciГіn y embudo propios.
model GrowthLink {
  id            String     @id @default(cuid())
  code          String     @unique // cГіdigo corto para /r/[code]
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId     String // referente dueГ±o del enlace
  cliente       Cliente    @relation("GrowthLinks", fields: [clienteId], references: [id], onDelete: Cascade)
  // Beneficio ofrecido en la landing (Beneficio Digital E8). Opcional.
  promocionId   String?
  promocion     Promocion? @relation("GrowthLinkBeneficio", fields: [promocionId], references: [id], onDelete: SetNull)
  campanaId     String?
  campana       Campana?   @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  titulo        String?
  mensaje       String?
  canal         String? // canal con el que se generГі/compartiГі
  duracionHoras Int? // duraciГіn configurable (1, 6, 12, 24, 72, 168вЂ¦)
  expiresAt     DateTime? // instante exacto de expiraciГіn (verificado en servidor)
  activo        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  eventos     ReferralEvent[]
  recompensas GrowthReward[]

  @@index([companyId, clienteId])
  @@index([campanaId])
  @@map("growth_links")
}

/// ConfiguraciГіn del programa de crecimiento por empresa (req #12). Cada
/// empresa decide quГ© premia y la duraciГіn por defecto de sus enlaces.
model GrowthConfig {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  landingActiva        Boolean  @default(true) // mostrar landing antes del registro
  duracionHorasDefault Int      @default(24) // expiraciГіn por defecto de enlaces
  premiaClic           Boolean  @default(false)
  premiaRegistro       Boolean  @default(true)
  premiaMembresia      Boolean  @default(true)
  premiaCompra         Boolean  @default(true)
  premiaRenovacion     Boolean  @default(false)
  config               Json     @default("{}") // extensible sin migrar
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("growth_configs")
}

/// Regla de recompensa 100% configurable por evento (req #9). Sin valores fijos
/// en cГіdigo: el admin define trigger, condiciГіn, beneficiario y recompensa.
model GrowthRule {
  id                    String             @id @default(cuid())
  companyId             String
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campanaId             String?
  campana               Campana?           @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  nombre                String
  trigger               GrowthTrigger
  valorCondicion        Int                @default(1) // ej. N_REFERIDOS => umbral
  planId                String? // condiciГіn: solo si comprГі este plan (ej. Gold)
  beneficiario          GrowthBeneficiario @default(REFERENTE)
  recompensaTipo        GrowthRewardTipo
  recompensaValor       Decimal            @default(0) @db.Decimal(10, 2)
  // Beneficio Digital (PromociГіn) a otorgar cuando recompensaTipo = BENEFICIO.
  recompensaPromocionId String?
  recompensaPromocion   Promocion?         @relation("GrowthRuleBeneficio", fields: [recompensaPromocionId], references: [id], onDelete: SetNull)
  activo                Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  recompensas GrowthReward[]

  @@index([companyId, activo])
  @@index([companyId, trigger, activo])
  @@map("growth_rules")
}

/// Recompensa REAL otorgada por el Growth Engine, con estado propio y entrega
/// idempotente. Cuando el tipo es BENEFICIO, `productoCompraId` referencia el
/// ProductoCompra (E8) generado como beneficio activo con QR.
model GrowthReward {
  id               String             @id @default(cuid())
  companyId        String
  ruleId           String
  rule             GrowthRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  clienteId        String // beneficiario (referente o referido)
  cliente          Cliente            @relation("GrowthRewards", fields: [clienteId], references: [id], onDelete: Cascade)
  growthLinkId     String?
  growthLink       GrowthLink?        @relation(fields: [growthLinkId], references: [id], onDelete: SetNull)
  referidoId       String? // vГ­nculo Referido que la disparГі (auditorГ­a)
  trigger          GrowthTrigger
  tipo             GrowthRewardTipo
  valor            Decimal            @db.Decimal(10, 2)
  descripcion      String
  estado           GrowthRewardEstado @default(PENDIENTE)
  productoCompraId String? // scalar: beneficio E8 entregado (si aplica)
  entregadaAt      DateTime?
  motivoRechazo    String?
  // Idempotencia: una recompensa por disparador Гєnico (regla+cliente+evento).
  dedupeKey        String             @unique
  createdAt        DateTime           @default(now())

  @@index([companyId, estado])
  @@index([clienteId])
  @@index([growthLinkId])
  @@map("growth_rewards")
}

/// Saldo de puntos y crГ©ditos del programa (wallet) por empresa y cliente.
model GrowthWallet {
  id        String   @id @default(cuid())
  companyId String
  clienteId String
  cliente   Cliente  @relation("GrowthWallet", fields: [clienteId], references: [id], onDelete: Cascade)
  puntos    Int      @default(0)
  creditos  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, clienteId])
  @@index([companyId])
  @@map("growth_wallets")
}

// ConfiguraciГіn de ComunicaciГіn y Soporte por empresa, 100% editable desde el
// panel. Conserva el nombre de tabla `whatsapp_config` por compatibilidad.
model WhatsAppConfig {
