generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AppRole {
  SUPERADMIN
  ADMIN_EMPRESA
  EMPLEADO
  CLIENTE
}

enum NotifTipo {
  PAGO_APROBADO
  PAGO_RECHAZADO
  NUEVO_COMPROBANTE
  MEMBRESIA_POR_VENCER
  MEMBRESIA_ACTIVADA
  PROMOCION_NUEVA
  RECOMPENSA_REFERIDO
  SISTEMA
  TICKET_NUEVO
  TICKET_RESPUESTA
  TICKET_ACTUALIZADO
}

enum TicketEstado {
  NUEVO
  EN_PROCESO
  ESPERANDO_CLIENTE
  RESUELTO
  CERRADO
}

enum TicketCategoria {
  PAGO
  MEMBRESIA
  BENEFICIOS
  APP
  OTRO
}

enum TicketAutor {
  CLIENTE
  ADMIN
  SISTEMA
}

enum MembershipEstado {
  PENDIENTE          // solicitada, sin pago
  PENDIENTE_PAGO     // comprobante enviado, esperando validación
  RECHAZADA          // pago rechazado por admin
  ACTIVA
  VENCIDA
  CANCELADA
}

enum MetodoPagoTipo {
  TRANSFERENCIA
  PRESENCIAL
}

enum AuditAccion {
  VISITA_CONFIRMADA
  PAGO_APROBADO
  PAGO_RECHAZADO
  MEMBRESIA_CANCELADA
  MEMBRESIA_RENOVADA
  QR_GENERADO
  QR_USADO
  COMPROBANTE_IMPRESO
  REFERIDO_COMPLETADO
  RECOMPENSA_OTORGADA
  NOTA_INTERNA
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  name        String
  role        AppRole  @default(CLIENTE)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     Membership[]
  visits          Visit[]        @relation("EmpleadoVisits")
  auditLogs       AuditLog[]
  comprobantes    Comprobante[]
  notificaciones  Notificacion[]

  @@map("users")
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        String    // "carwash" | "restaurante"
  description String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  users         User[]
  plans         Plan[]
  clientes      Cliente[]
  sucursales    Sucursal[]
  metodosPago   MetodoPago[]
  auditLogs     AuditLog[]
  promociones   Promocion[]
  referidos     Referido[]
  reglasRecompensa ReglaRecompensa[]
  whatsappConfig WhatsAppConfig?
  faqs          FaqItem[]
  tickets       SupportTicket[]

  @@map("companies")
}

// Sucursales físicas de una empresa
model Sucursal {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  nombre    String
  direccion String?
  telefono  String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  visits    Visit[]

  @@map("sucursales")
}

// Métodos de pago configurables por empresa (sin tocar código)
model MetodoPago {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  tipo          MetodoPagoTipo
  nombre        String         // "Banco Popular", "Pago en sucursal"
  titular       String?
  numeroCuenta  String?
  tipoCuenta    String?        // "Ahorro", "Corriente"
  instrucciones String?        // texto libre para mostrar al cliente
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]

  @@map("metodos_pago")
}

// Promociones publicadas por una empresa, visibles para sus clientes
// (incluyendo clientes afiliados a varias empresas, vía Cliente.companyId).
model Promocion {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  titulo         String
  descripcion    String
  imagenUrl      String?
  vigenciaDesde  DateTime  @default(now())
  vigenciaHasta  DateTime?
  activo         Boolean   @default(true)
  publicadaEn    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId, activo])
  @@map("promociones")
}

model Plan {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id])
  nombre           String
  precio           Decimal      @db.Decimal(10, 2)
  lavadosIncluidos Int          @default(0)
  esIlimitado      Boolean      @default(false)
  descripcion      String?
  beneficios       String[]
  vigenciaDias     Int          @default(30) // duración del período
  condiciones      String?      // texto de condiciones/restricciones
  activo           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  memberships      Membership[]

  @@map("plans")
}

model Cliente {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  supabaseId      String
  nombre          String
  telefono        String?
  email           String
  fechaNacimiento DateTime?
  avatarUrl       String?
  codigoReferido  String       @unique @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  vehiculos       Vehiculo[]
  memberships     Membership[]
  qrTokens        QrToken[]    // vacío hasta que tenga membresía activa
  visits          Visit[]
  referidosHechos Referido[]   @relation("Referente")
  referidoComo    Referido[]   @relation("Referido")
  tickets         SupportTicket[]

  @@unique([supabaseId, companyId])
  @@map("clientes")
}

enum ReferidoEstado {
  PENDIENTE
  COMPLETADO
}

enum CondicionRecompensa {
  N_REFERIDOS_COMPLETADOS
}

enum TipoRecompensa {
  LAVADOS_GRATIS
  DESCUENTO_PORCENTAJE
  DESCUENTO_MONTO
}

// Referido: vínculo entre quien invita y quien se registró con su código.
model Referido {
  id                  String         @id @default(cuid())
  companyId           String
  company             Company        @relation(fields: [companyId], references: [id])
  referenteClienteId  String
  referenteCliente    Cliente        @relation("Referente", fields: [referenteClienteId], references: [id])
  referidoClienteId   String         @unique
  referidoCliente     Cliente        @relation("Referido", fields: [referidoClienteId], references: [id])
  estado              ReferidoEstado @default(PENDIENTE)
  recompensaAplicada  Boolean        @default(false)
  createdAt           DateTime       @default(now())
  completadoEn        DateTime?

  @@index([companyId, referenteClienteId])
  @@map("referidos")
}

// Regla de recompensa 100% configurable desde el panel admin: sin valores
// fijos en código. El admin define cuándo y qué recompensa otorgar.
model ReglaRecompensa {
  id               String              @id @default(cuid())
  companyId        String
  company          Company             @relation(fields: [companyId], references: [id])
  nombre           String
  condicion        CondicionRecompensa
  valorCondicion   Int                 // ej: 3 referidos completados
  tipoRecompensa   TipoRecompensa
  valorRecompensa  Decimal             @db.Decimal(10, 2) // lavados, % o monto según tipo
  activo           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([companyId, activo])
  @@map("reglas_recompensa")
}

// Configuración de Comunicación y Soporte por empresa, 100% editable desde el
// panel. Conserva el nombre de tabla `whatsapp_config` por compatibilidad.
model WhatsAppConfig {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id])
  codigoPais       String   @default("+1") // ej: +52
  numero           String   // solo dígitos nacionales, ej: 5512345678
  mensajePlantilla String   @default("Hola, quisiera más información.")
  activo           Boolean  @default(true) // mostrar botón de WhatsApp al cliente
  correoSoporte    String?  // correo de soporte, ej: soporte@empresa.com
  horaInicio       String?  // "09:00"
  horaCierre       String?  // "18:00"
  diasLaborales    String?  // CSV de índices de día 0..6 (0=Dom), ej: "1,2,3,4,5"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("whatsapp_config")
}

// Preguntas frecuentes administrables por empresa, visibles en el Centro de Ayuda.
model FaqItem {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  pregunta  String
  respuesta String
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, activo])
  @@map("faq_items")
}

// Tickets de soporte creados por clientes y gestionados por administradores.
model SupportTicket {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  clienteId   String
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  asunto      String
  categoria   TicketCategoria @default(OTRO)
  estado      TicketEstado    @default(NUEVO)
  adjuntoUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  mensajes    TicketMensaje[]

  @@index([companyId, estado])
  @@index([clienteId])
  @@map("support_tickets")
}

// Mensajes/eventos de un ticket: conversación cliente↔admin, notas internas
// (solo visibles para admin) y eventos de sistema (cambios de estado).
model TicketMensaje {
  id            String        @id @default(cuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  autorTipo     TicketAutor
  autorNombre   String
  cuerpo        String
  esNotaInterna Boolean       @default(false)
  createdAt     DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_mensajes")
}

model Vehiculo {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  marca     String
  modelo    String
  anio      Int
  color     String
  placa     String?
  createdAt DateTime @default(now())

  visits    Visit[]

  @@map("vehiculos")
}

model Membership {
  id               String           @id @default(cuid())
  clienteId        String
  cliente          Cliente          @relation(fields: [clienteId], references: [id])
  planId           String
  plan             Plan             @relation(fields: [planId], references: [id])
  userId           String?          // empleado/admin que la creó
  user             User?            @relation(fields: [userId], references: [id])
  metodoPagoId     String?          // método de pago seleccionado
  metodoPago       MetodoPago?      @relation(fields: [metodoPagoId], references: [id])
  estado           MembershipEstado @default(PENDIENTE)
  // Pago
  comprobanteUrl   String?          // URL del comprobante subido (Supabase Storage)
  comprobanteNota  String?          // nota del cliente al enviar comprobante
  rechazadoReason  String?          // motivo de rechazo por admin
  adminNota        String?          // nota interna del admin, no visible al cliente
  pagoConfirmado   Boolean          @default(false)
  montoPagado      Decimal?         @db.Decimal(10, 2)
  // Período activo
  fechaInicio      DateTime?
  fechaVencimiento DateTime?
  lavadosRestantes Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  visits           Visit[]
  comprobantes     Comprobante[]

  @@index([estado])
  @@index([clienteId])
  @@map("memberships")
}

// QR generado SOLO al activar membresía. Permanente y único por cliente+empresa.
model QrToken {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  token     String   @unique @default(cuid())
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([clienteId, activo])
  @@map("qr_tokens")
}

model Visit {
  id           String    @id @default(cuid())
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id])
  vehiculoId   String?
  vehiculo     Vehiculo? @relation(fields: [vehiculoId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  sucursalId   String?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])
  empleadoId   String?
  empleado     User?     @relation("EmpleadoVisits", fields: [empleadoId], references: [id])
  servicio     String
  descontado   Boolean   @default(false)
  fechaVisita  DateTime  @default(now())
  notas        String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  comprobante  Comprobante?

  @@map("visits")
}

// Comprobante generado al confirmar visita. Registra impresiones.
model Comprobante {
  id           String     @id @default(cuid())
  visitId      String     @unique
  visit        Visit      @relation(fields: [visitId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  numero       String     @unique // número secuencial legible (ej. "COMP-000123")
  impresiones  Int        @default(0)
  ultimaImpresion DateTime?
  creadoPorId  String?
  creadoPor    User?      @relation(fields: [creadoPorId], references: [id])
  createdAt    DateTime   @default(now())

  @@map("comprobantes")
}

// Registro de auditoría inmutable — insert only, nunca se actualiza ni elimina
model AuditLog {
  id          String      @id @default(cuid())
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  userId      String?     // quien realizó la acción
  user        User?       @relation(fields: [userId], references: [id])
  accion      AuditAccion
  entidadTipo String      // "Visit", "Membership", "QrToken", etc.
  entidadId   String
  payload     Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([accion])
  @@index([entidadTipo, entidadId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notificacion {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tipo      NotifTipo
  titulo    String
  mensaje   String
  href      String?   // ruta a la que lleva al hacer clic
  leida     Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  @@map("notificaciones")
}
