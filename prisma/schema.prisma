// F3.3: Publicaciones de empresa вЂ” eventos, noticias y beneficios permanentes.
// Un solo modelo flexible: fechaEvento/lugar solo aplican a EVENTO.
enum PostTipo {
  EVENTO
  NOTICIA
  BENEFICIO
}

model CompanyPost {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipo        PostTipo
  titulo      String
  contenido   String
  imagenUrl   String?
  fechaEvento DateTime? // solo EVENTO
  lugar       String? // solo EVENTO
  campanaId   String?
  campana     Campana?  @relation(fields: [campanaId], references: [id], onDelete: SetNull)
  activo      Boolean   @default(true)
  publicadaEn DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId, tipo, activo])
  @@index([tipo, fechaEvento])
  @@map("company_posts")
}

// F4.4: notas internas del CRM вЂ” mГєltiples por cliente, con autor y fecha.
// Solo visibles para el equipo de la empresa (nunca para el cliente).
model ClienteNota {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  autorId   String?
  autor     User?    @relation(fields: [autorId], references: [id], onDelete: SetNull)
  texto     String
  createdAt DateTime @default(now())

  @@index([clienteId, createdAt])
  @@map("cliente_notas")
}

// вљ пёЏ DESAMBIGUACIГ“N: hay TRES modelos "campaГ±a" con propГіsitos distintos
// (ver docs/GUIA_LENGUAJE_MEMBEGO.md В§1.4):
//   1. Campana            в†’ agrupador de promociones/posts (/admin/campanas).
//   2. CampanaInvitacion  в†’ programa "Invita y Gana" (/admin/invitaciones).
//   3. MarketingCampaign  в†’ banners vivos del Home (/admin/marketing).
//
// F4.6: campaГ±as вЂ” agrupan promociones y publicaciones bajo un mismo
// paraguas (ej. "Black Friday") para medirlas en conjunto.
model Campana {
  id          String    @id @default(cuid())
