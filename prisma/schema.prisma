model Membership {
  id                  String           @id @default(cuid())
  clienteId           String
  cliente             Cliente          @relation(fields: [clienteId], references: [id])
  companyId           String
  company             Company          @relation(fields: [companyId], references: [id])
  planId              String
  plan                Plan             @relation(fields: [planId], references: [id])
  // Cambio de plan solicitado por el cliente mientras la membresГ­a sigue ACTIVA.
  // El admin lo aprueba (con el comprobante) y se aplica; hasta entonces el plan
  // vigente no cambia. null = sin cambio pendiente.
  planIdSolicitado    String?
  planSolicitado      Plan?            @relation("PlanSolicitado", fields: [planIdSolicitado], references: [id])
  userId              String? // empleado/admin que la creГі
  user                User?            @relation(fields: [userId], references: [id])
  metodoPagoId        String? // mГ©todo de pago seleccionado
  metodoPago          MetodoPago?      @relation(fields: [metodoPagoId], references: [id])
  // Pago presencial (POS): referencia Гєnica que el cliente muestra en caja y
  // sucursal elegida para pagar. Null en pagos por transferencia.
  referencia          String?          @unique
  sucursalPagoId      String?
  sucursalPago        Sucursal?        @relation("MembershipSucursalPago", fields: [sucursalPagoId], references: [id])
  estado              MembershipEstado @default(PENDIENTE)
  // Pago
  comprobanteUrl      String? // URL del comprobante subido (Supabase Storage)
  comprobanteNota     String? // nota del cliente al enviar comprobante
  rechazadoReason     String? // motivo de rechazo por admin
  adminNota           String? // nota interna del admin, no visible al cliente
  pagoConfirmado      Boolean          @default(false)
  montoPagado         Decimal?         @db.Decimal(10, 2)
  // O-13: descuento de bienvenida congelado al solicitar el plan (null = sin
  // descuento). Solo se aplica si la membresГ­a nunca se activГі (fechaInicio null).
  descuentoBienvenida Decimal?         @db.Decimal(10, 2)
  // PerГ­odo activo
  fechaInicio         DateTime?
  fechaVencimiento    DateTime?
  lavadosRestantes    Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  visits       Visit[]
  comprobantes Comprobante[]
  qrTokens     QrToken[]

  transacciones Transaction[]

  @@unique([clienteId, companyId])
  @@index([estado])
  @@index([clienteId])
  @@index([companyId])
  // Conteos por plan (reportes, borrado seguro de planes).
  @@index([planId])
  // PatrГіn caliente de dashboards y automatizaciones: membresГ­as de una
  // empresa por estado y vencimiento (activas, por vencer, pendientes).
  @@index([companyId, estado, fechaVencimiento])
  @@map("memberships")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE E5 В· PRODUCTOS COMERCIALES (compras)
// Ciclo de compra unificado: hoy lo usan las promociones; las membresГ­as
// comparten el mismo flujo conceptual (solicitud в†’ pago в†’ validaciГіn в†’
// activaciГіn в†’ QR в†’ consumo) y podrГЎn migrar a esta tabla sin rediseГ±o.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum ProductoComercialTipo {
  PROMOCION
  MEMBRESIA // reservado: unificaciГіn futura del ciclo de membresГ­as
}

enum CompraEstado {
  SOLICITADA // el cliente pidiГі el producto
  PENDIENTE_PAGO // esperando la transferencia del cliente
  EN_VALIDACION // comprobante enviado, esperando al admin
  APROBADA // pago validado (transitorio antes de activar)
  ACTIVA // beneficio disponible, QR emitido
  RECHAZADA // pago rechazado (puede reintentar)
  CONSUMIDA // sin usos restantes
  EXPIRADA // venciГі sin consumirse por completo
  CANCELADA // cancelada por el cliente o el admin
}

model ProductoCompra {
  id     String                @id @default(cuid())
  tipo   ProductoComercialTipo @default(PROMOCION)
  estado CompraEstado          @default(SOLICITADA)

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  clienteId   String
  cliente     Cliente    @relation(fields: [clienteId], references: [id])
  promocionId String?
  promocion   Promocion? @relation(fields: [promocionId], references: [id])

  // Pago (transferencia hoy; el puerto de pagos permite pasarelas futuras)
  metodoPagoId       String?
  metodoPago         MetodoPago? @relation(fields: [metodoPagoId], references: [id])
  precioCongelado    Decimal?    @db.Decimal(10, 2) // precio al solicitar
  montoPagado        Decimal?    @db.Decimal(10, 2)
  pagoConfirmado     Boolean     @default(false)
  comprobanteUrl     String?
  comprobanteNota    String?
  transferenciaFecha DateTime? // fecha/hora declarada de la transferencia
  rechazadoReason    String?
  adminNota          String?
  aprobadaPorId      String?
  aprobadaPor        User?       @relation("CompraAprobadaPor", fields: [aprobadaPorId], references: [id])
  // Pago presencial (POS): referencia Гєnica + sucursal elegida.
  referencia         String?     @unique
  sucursalPagoId     String?
  sucursalPago       Sucursal?   @relation("CompraSucursalPago", fields: [sucursalPagoId], references: [id])

  // Beneficio activo
  usosIncluidos    Int       @default(1)
  usosRestantes    Int       @default(0)
  fechaActivacion  DateTime?
  fechaVencimiento DateTime? // null = sin vencimiento
  consumidaAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transiciones ProductoCompraTransicion[]
  qrTokens     QrToken[]

  @@index([companyId, estado])
  @@index([clienteId, estado])
  @@index([promocionId, estado])
  @@index([companyId, createdAt])
  @@map("producto_compras")
}

// BitГЎcora inmutable de estados de una compra (quiГ©n, cuГЎndo, por quГ©).
model ProductoCompraTransicion {
  id        String         @id @default(cuid())
  compraId  String
  compra    ProductoCompra @relation(fields: [compraId], references: [id], onDelete: Cascade)
  desde     CompraEstado?
  hacia     CompraEstado
  motivo    String?
  userId    String?
  user      User?          @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())

  @@index([compraId, createdAt])
  @@map("producto_compra_transiciones")
}

// QR de acceso de un producto activo: membresГ­a O compra de promociГіn (E5).
// Exactamente el mismo sistema de un solo uso con regeneraciГіn para ambos.
model QrToken {
  id               String          @id @default(cuid())
  clienteId        String
  cliente          Cliente         @relation(fields: [clienteId], references: [id])
  membresiaId      String?
  membership       Membership?     @relation(fields: [membresiaId], references: [id], onDelete: Cascade)
  // FASE E5: QR de una compra de promociГіn (excluyente con membresiaId).
  compraId         String?
  compra           ProductoCompra? @relation(fields: [compraId], references: [id], onDelete: Cascade)
  token            String          @unique @default(cuid())
  activo           Boolean         @default(true)
  // Compartir el QR (p. ej. por WhatsApp) no consume el token вЂ”sigue siendo de
  // un solo usoвЂ” pero sГ­ queda registrado: cuГЎntas veces y cuГЎndo la Гєltima.
  compartidoCount  Int             @default(0)
  ultimoCompartido DateTime?
  createdAt        DateTime        @default(now())

  transaccionUso Transaction? @relation("TransactionQrUsado")

  @@index([clienteId, activo])
  @@index([membresiaId])
  @@index([compraId])
  @@map("qr_tokens")
}

model Visit {
  id           String     @id @default(cuid())
  clienteId    String
  cliente      Cliente    @relation(fields: [clienteId], references: [id])
  vehiculoId   String?
  vehiculo     Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  sucursalId   String?
  sucursal     Sucursal?  @relation(fields: [sucursalId], references: [id])
  empleadoId   String?
  empleado     User?      @relation("EmpleadoVisits", fields: [empleadoId], references: [id])
  servicio     String
  descontado   Boolean    @default(false)
  fechaVisita  DateTime   @default(now())
  notas        String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  comprobante Comprobante?

  // Postgres no indexa FKs automГЎticamente. Visitas se consultan por cliente,
  // por membresГ­a y por fecha (historial, reportes, "clientes frecuentes").
  transaccion Transaction?

  @@index([clienteId])
  @@index([membershipId])
  @@index([fechaVisita])
  @@index([vehiculoId])
  @@index([sucursalId])
  @@map("visits")
}

// Comprobante generado al confirmar visita. Registra impresiones.
model Comprobante {
  id              String     @id @default(cuid())
  visitId         String     @unique
  visit           Visit      @relation(fields: [visitId], references: [id])
  membershipId    String
  membership      Membership @relation(fields: [membershipId], references: [id])
  numero          String     @unique // nГєmero secuencial legible (ej. "COMP-000123")
  impresiones     Int        @default(0)
  ultimaImpresion DateTime?
  creadoPorId     String?
  creadoPor       User?      @relation(fields: [creadoPorId], references: [id])
  createdAt       DateTime   @default(now())

  @@index([membershipId])
  @@map("comprobantes")
}

// Registro de auditorГ­a inmutable вЂ” insert only, nunca se actualiza ni elimina
model AuditLog {
  id          String      @id @default(cuid())
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  userId      String? // quien realizГі la acciГіn
  user        User?       @relation(fields: [userId], references: [id])
  accion      AuditAccion
  entidadTipo String // "Visit", "Membership", "QrToken", etc.
  entidadId   String
  payload     Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([accion])
  @@index([entidadTipo, entidadId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notificacion {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tipo      NotifTipo
  titulo    String
  mensaje   String
  href      String? // ruta a la que lleva al hacer clic
  leida     Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  @@map("notificaciones")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE 2: MARKETPLACE
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model BusinessCategory {
