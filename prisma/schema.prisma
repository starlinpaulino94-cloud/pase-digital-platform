generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AppRole {
  SUPERADMIN
  ADMIN_EMPRESA
  EMPLEADO
  CLIENTE
}

enum NotifTipo {
  PAGO_APROBADO
  PAGO_RECHAZADO
  NUEVO_COMPROBANTE
  MEMBRESIA_POR_VENCER
  MEMBRESIA_ACTIVADA
  SISTEMA
}

enum MembershipEstado {
  PENDIENTE          // solicitada, sin pago
  PENDIENTE_PAGO     // comprobante enviado, esperando validación
  RECHAZADA          // pago rechazado por admin
  ACTIVA
  VENCIDA
  CANCELADA
}

enum MetodoPagoTipo {
  TRANSFERENCIA
  PRESENCIAL
}

enum AuditAccion {
  VISITA_CONFIRMADA
  PAGO_APROBADO
  PAGO_RECHAZADO
  MEMBRESIA_CANCELADA
  MEMBRESIA_RENOVADA
  QR_GENERADO
  COMPROBANTE_IMPRESO
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  name        String
  role        AppRole  @default(CLIENTE)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     Membership[]
  visits          Visit[]        @relation("EmpleadoVisits")
  auditLogs       AuditLog[]
  comprobantes    Comprobante[]
  notificaciones  Notificacion[]

  @@map("users")
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        String    // "carwash" | "restaurante"
  description String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  users         User[]
  plans         Plan[]
  clientes      Cliente[]
  sucursales    Sucursal[]
  metodosPago   MetodoPago[]
  auditLogs     AuditLog[]

  @@map("companies")
}

// Sucursales físicas de una empresa
model Sucursal {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  nombre    String
  direccion String?
  telefono  String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  visits    Visit[]

  @@map("sucursales")
}

// Métodos de pago configurables por empresa (sin tocar código)
model MetodoPago {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  tipo          MetodoPagoTipo
  nombre        String         // "Banco Popular", "Pago en sucursal"
  titular       String?
  numeroCuenta  String?
  tipoCuenta    String?        // "Ahorro", "Corriente"
  instrucciones String?        // texto libre para mostrar al cliente
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]

  @@map("metodos_pago")
}

model Plan {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id])
  nombre           String
  precio           Decimal      @db.Decimal(10, 2)
  lavadosIncluidos Int          @default(0)
  esIlimitado      Boolean      @default(false)
  descripcion      String?
  beneficios       String[]
  vigenciaDias     Int          @default(30) // duración del período
  condiciones      String?      // texto de condiciones/restricciones
  activo           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  memberships      Membership[]

  @@map("plans")
}

model Cliente {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  supabaseId      String
  nombre          String
  telefono        String?
  email           String
  fechaNacimiento DateTime?
  avatarUrl       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  vehiculos       Vehiculo[]
  memberships     Membership[]
  qrTokens        QrToken[]    // vacío hasta que tenga membresía activa
  visits          Visit[]

  @@unique([supabaseId, companyId])
  @@map("clientes")
}

model Vehiculo {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  marca     String
  modelo    String
  anio      Int
  color     String
  placa     String?
  createdAt DateTime @default(now())

  visits    Visit[]

  @@map("vehiculos")
}

model Membership {
  id               String           @id @default(cuid())
  clienteId        String
  cliente          Cliente          @relation(fields: [clienteId], references: [id])
  planId           String
  plan             Plan             @relation(fields: [planId], references: [id])
  userId           String?          // empleado/admin que la creó
  user             User?            @relation(fields: [userId], references: [id])
  metodoPagoId     String?          // método de pago seleccionado
  metodoPago       MetodoPago?      @relation(fields: [metodoPagoId], references: [id])
  estado           MembershipEstado @default(PENDIENTE)
  // Pago
  comprobanteUrl   String?          // URL del comprobante subido (Supabase Storage)
  comprobanteNota  String?          // nota del cliente al enviar comprobante
  rechazadoReason  String?          // motivo de rechazo por admin
  pagoConfirmado   Boolean          @default(false)
  montoPagado      Decimal?         @db.Decimal(10, 2)
  // Período activo
  fechaInicio      DateTime?
  fechaVencimiento DateTime?
  lavadosRestantes Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  visits           Visit[]
  comprobantes     Comprobante[]

  @@map("memberships")
}

// QR generado SOLO al activar membresía. Permanente y único por cliente+empresa.
model QrToken {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  token     String   @unique @default(cuid())
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("qr_tokens")
}

model Visit {
  id           String    @id @default(cuid())
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id])
  vehiculoId   String?
  vehiculo     Vehiculo? @relation(fields: [vehiculoId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  sucursalId   String?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])
  empleadoId   String?
  empleado     User?     @relation("EmpleadoVisits", fields: [empleadoId], references: [id])
  servicio     String
  descontado   Boolean   @default(false)
  fechaVisita  DateTime  @default(now())
  notas        String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  comprobante  Comprobante?

  @@map("visits")
}

// Comprobante generado al confirmar visita. Registra impresiones.
model Comprobante {
  id           String     @id @default(cuid())
  visitId      String     @unique
  visit        Visit      @relation(fields: [visitId], references: [id])
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  numero       String     @unique // número secuencial legible (ej. "COMP-000123")
  impresiones  Int        @default(0)
  ultimaImpresion DateTime?
  creadoPorId  String?
  creadoPor    User?      @relation(fields: [creadoPorId], references: [id])
  createdAt    DateTime   @default(now())

  @@map("comprobantes")
}

// Registro de auditoría inmutable — insert only, nunca se actualiza ni elimina
model AuditLog {
  id          String      @id @default(cuid())
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  userId      String?     // quien realizó la acción
  user        User?       @relation(fields: [userId], references: [id])
  accion      AuditAccion
  entidadTipo String      // "Visit", "Membership", "QrToken", etc.
  entidadId   String
  payload     Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([accion])
  @@index([entidadTipo, entidadId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notificacion {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tipo      NotifTipo
  titulo    String
  mensaje   String
  href      String?   // ruta a la que lleva al hacer clic
  leida     Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  @@map("notificaciones")
}
