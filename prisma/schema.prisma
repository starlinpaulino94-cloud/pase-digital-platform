  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  fechaInicio DateTime?
  fechaFin    DateTime?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  promociones Promocion[]
  posts       CompanyPost[]

  // Growth Engine 3.0: enlaces y reglas ligados a esta campaГ±a.
  growthLinks GrowthLink[]
  growthRules GrowthRule[]

  @@index([companyId, activo])
  @@map("campanas")
}

// F5.2: intereses del cliente (categorГ­as favoritas, cross-empresa).
// Alimentan las recomendaciones del feed y el onboarding B2C.
model UserInteres {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([userId, categoryId])
  @@index([categoryId])
  @@map("user_intereses")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE 1 (REDISEГ‘O DEL NГљCLEO): MOTOR UNIVERSAL DE REGLAS
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Infraestructura genГ©rica y multi-tenant para el futuro Rule Engine. NO
// contiene lГіgica de promociones, membresГ­as, QR ni cupones: solo el modelo
// de datos de reglas configurables. NingГєn flujo actual lee estas tablas.

/// Ciclo de vida de una regla (independiente del interruptor `activo`).
enum RuleStatus {
  DRAFT // en ediciГіn, nunca se evalГєa
  PUBLISHED // publicada; se evalГєa si ademГЎs `activo` = true y estГЎ en ventana de vigencia
  ARCHIVED // retirada; se conserva como historial, nunca se evalГєa
}

/// CГіmo se combinan las condiciones de una regla (modo plano, Fase 1). Cuando
/// la regla usa grupos (Fase 2) este campo se ignora en favor del ГЎrbol.
enum RuleMatchType {
  ALL // AND: todas las condiciones deben cumplirse
  ANY // OR: basta con que se cumpla una condiciГіn
}

/// Operador lГіgico de un grupo de condiciones (Fase 2). Permite construir
/// ГЎrboles booleanos de profundidad ilimitada.
enum RuleLogicalOperator {
  AND // todas las condiciones/hijos deben cumplirse
  OR // al menos uno debe cumplirse
  NOT // negaciГіn del conjunto de hijos (NOT del AND de los hijos)
  XOR // exactamente uno de los hijos debe cumplirse
}

/// Agrupa reglas por dominio funcional (ej. "ValidaciГіn QR", "MembresГ­as",
/// "Beneficios"). Puramente organizativo; el motor puede filtrar por `key`.
model RuleGroup {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key         String // identificador estable legible por mГЎquina, ej. "qr_validation"
  nombre      String
  descripcion String?
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules Rule[]

  @@unique([companyId, key])
  @@index([companyId, activo])
  @@map("rule_groups")
}

/// Regla configurable. El motor la evalГєa contra un RuleContext y, si se
/// cumple, dispara sus acciones. No conoce el negocio: campos y valores son
/// genГ©ricos (dot-paths + JSON).
model Rule {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupId     String?
  group       RuleGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  nombre      String
  descripcion String?
  status      RuleStatus    @default(DRAFT)
  activo      Boolean       @default(true) // interruptor de encendido, independiente del ciclo de vida
  prioridad   Int           @default(0) // mayor = se evalГєa primero
  version     Int           @default(1) // se incrementa en cada cambio (base para versionado)
  matchType   RuleMatchType @default(ALL)
  validoDesde DateTime? // ventana de vigencia opcional (null = sin lГ­mite inferior)
  validoHasta DateTime? // null = sin lГ­mite superior
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  conditions      RuleCondition[]
  conditionGroups RuleConditionGroup[]
  actions         RuleAction[]
  logs            RuleExecutionLog[]
  // Fase 4: reglas reutilizadas por promociones (sin duplicar).
  promotionRules  PromotionRule[]

  // Consulta caliente del motor: reglas de una empresa evaluables por estado.
  @@index([companyId, status, activo])
  @@index([groupId])
  @@index([companyId, prioridad])
  @@map("rules")
}

/// CondiciГіn atГіmica de una regla. `campo` es un dot-path dentro del contexto
/// (ej. "cliente.puntos"), `operador` es la clave de un operador del registro
/// extensible (ej. "gte") y `valor` es el valor esperado en JSON.
model RuleCondition {
  id            String              @id @default(cuid())
  ruleId        String
  rule          Rule                @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  // Fase 2: grupo al que pertenece la condiciГіn dentro del ГЎrbol booleano.
  // null = cuelga directamente de la raГ­z de la regla (modo plano de Fase 1).
  groupId       String?
  group         RuleConditionGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  campo         String // dot-path dentro del RuleContext, ej. "cliente.membresiaActiva"
  operador      String // id del operador en el registro, ej. "eq", "gte", "in"
  valor         Json                @default("null") // valor esperado (comparaciГіn)
  tipoValor     String              @default("STRING") // legacy Fase 1: guГ­a de coerciГіn del valor JSON
  // Fase 2: tipo de condiciГіn (registro extensible, ej. "field") y tipo de dato
  // evaluado (TEXT|NUMBER|DATE|TIME|BOOLEAN|LIST|OBJECT|ENUM|JSON) para validar
  // compatibilidad operadorв†”dato.
  conditionType String              @default("field")
  dataType      String              @default("TEXT")
  orden         Int                 @default(0)
  createdAt     DateTime            @default(now())

  @@index([ruleId, orden])
  @@index([groupId])
  @@map("rule_conditions")
}

/// Grupo de condiciones (Fase 2). Nodo interno del ГЎrbol booleano de una regla:
/// combina sus condiciones e hijos con un RuleLogicalOperator. Se auto-referencia
/// (`parentId`) para anidar sin lГ­mite. Un grupo sin `parentId` es una raГ­z.
model RuleConditionGroup {
  id        String               @id @default(cuid())
  ruleId    String
  rule      Rule                 @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    RuleConditionGroup?  @relation("RuleGroupTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  RuleConditionGroup[] @relation("RuleGroupTree")
  operator  RuleLogicalOperator  @default(AND)
  orden     Int                  @default(0)
  createdAt DateTime             @default(now())

  conditions RuleCondition[]

  @@index([ruleId])
  @@index([parentId])
  @@map("rule_condition_groups")
}

/// AcciГіn a ejecutar cuando la regla se cumple. En esta fase SOLO se almacena
/// la estructura: no hay handlers reales registrados. `tipo` es la clave de un
/// handler del registro extensible; `params` su configuraciГіn en JSON.
model RuleAction {
  id            String   @id @default(cuid())
  ruleId        String
  rule          Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tipo          String // clave del handler en el registro, ej. "grant_benefit" (aГєn sin implementar)
  params        Json     @default("{}")
  orden         Int      @default(0) // prioridad/orden de ejecuciГіn (menor = antes)
  // Fase 3: configuraciГіn de la acciГіn por DATOS (no por cГіdigo).
  obligatoria   Boolean  @default(true) // true = su fallo marca la ejecuciГіn como fallida
  maxReintentos Int      @default(0) // reintentos ante error (0 = un solo intento)
  activa        Boolean  @default(true) // interruptor: si false, se omite (SKIPPED)
  version       Int      @default(1) // versiГіn de la configuraciГіn de la acciГіn
  createdAt     DateTime @default(now())

  @@index([ruleId, orden])
  @@map("rule_actions")
}

/// Registro de auditorГ­a de cada evaluaciГіn del motor. Estructura preparada
/// para observabilidad; el motor la persiste solo si se le inyecta un sink
/// Prisma (por defecto usa un sink no-op).
model RuleExecutionLog {
  id         String   @id @default(cuid())
  ruleId     String?
  rule       Rule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  matched    Boolean // si la regla se cumpliГі
  resultado  Json     @default("{}") // resumen de acciones/resultado
  contexto   Json     @default("{}") // snapshot (posiblemente saneado) del contexto
  duracionMs Int      @default(0)
  error      String? // mensaje si la evaluaciГіn/ejecuciГіn fallГі
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([ruleId])
  @@map("rule_execution_logs")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE 4: FRAMEWORK UNIVERSAL DE PROMOCIONES
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Una promociГіn es una entidad CONFIGURABLE sin lГіgica programada: compone
// informaciГіn general + reglas (Rule Engine) + acciones (Action Engine) +
// restricciones + ciclo de vida + versionado + auditorГ­a. Es independiente de
// la industria y del modelo `Promocion` (marketplace) existente, que NO se
// toca. Multi-tenant: todo cuelga de companyId. NingГєn flujo la consume aГєn.

/// Ciclo de vida de una promociГіn. Extensible.
enum PromotionStatus {
  DRAFT // borrador
  PENDING // pendiente de revisiГіn/aprobaciГіn
  SCHEDULED // programada (con fecha futura)
  ACTIVE // activa
  PAUSED // pausada temporalmente
  SUSPENDED // suspendida (por incidencia/decisiГіn)
  ENDED // finalizada (fin natural)
  ARCHIVED // archivada (histГіrico)
  CANCELLED // cancelada
}

/// DefiniciГіn general y ADMINISTRATIVA de una promociГіn. Sin lГіgica: la lГіgica
/// vive en las reglas (Rule Engine) y las acciones (Action Engine) asociadas.
model Promotion {
  id           String          @id @default(cuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  categoria    String? // etiqueta libre de organizaciГіn, NUNCA tipo de industria
  status       PromotionStatus @default(DRAFT)
  prioridad    Int             @default(0) // mayor = mГЎs prioritaria ante conflictos
  inicioEn     DateTime? // ventana de vigencia (programaciГіn)
  finEn        DateTime?
  config       Json            @default("{}") // configuraciГіn flexible (parГЎmetros arbitrarios)
  metadata     Json            @default("{}") // metadatos libres
  version      Int             @default(1) // versiГіn actual
  creadoPorId  String? // usuario que la creГі
  editadoPorId String? // Гєltimo usuario que la modificГі
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  rules        PromotionRule[]
  actions      PromotionAction[]
  restrictions PromotionRestriction[]
  versions     PromotionVersion[]
  audits       PromotionAudit[]

  @@index([companyId, status])
  @@index([companyId, prioridad])
  @@index([companyId, status, inicioEn, finEn])
  @@map("promotions")
}

/// Mapeo promociГіnв†’regla (Rule Engine). Reutiliza reglas SIN duplicarlas.
model PromotionRule {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  ruleId      String
  rule        Rule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  orden       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([promotionId, ruleId]) // no duplicar la misma regla en una promociГіn
  @@index([ruleId])
  @@map("promotion_rules")
}

/// Mapeo promociГіnв†’acciГіn (Action Engine). La promociГіn NUNCA ejecuta acciones
/// directamente: aporta la configuraciГіn que el Action Engine ejecutarГЎ.
model PromotionAction {
  id            String    @id @default(cuid())
  promotionId   String
  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tipo          String // clave del catГЎlogo del Action Engine
  params        Json      @default("{}")
  orden         Int       @default(0)
  obligatoria   Boolean   @default(true)
  maxReintentos Int       @default(0)
  activa        Boolean   @default(true)
  version       Int       @default(1)
  createdAt     DateTime  @default(now())

  @@index([promotionId, orden])
  @@map("promotion_actions")
}

/// RestricciГіn universal de una promociГіn (config, sin validaciГіn programada
/// todavГ­a). `tipo` proviene de un catГЎlogo (MAX_USES_TOTAL, PER_CLIENT, вЂ¦).
model PromotionRestriction {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tipo        String // clave del catГЎlogo de restricciones
  valor       Int? // lГ­mite numГ©rico cuando aplica (usos, cantidadвЂ¦)
  config      Json      @default("{}") // parГЎmetros adicionales (ventana, ГЎmbitoвЂ¦)
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([promotionId])
  @@map("promotion_restrictions")
}

/// InstantГЎnea inmutable de una versiГіn de la promociГіn. Nunca se borra: es el
/// historial de versionado.
model PromotionVersion {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json // definiciГіn completa congelada en esa versiГіn
  resumen     String? // resumen del cambio
  creadoPorId String?
  createdAt   DateTime  @default(now())

  @@unique([promotionId, version])
  @@index([promotionId])
  @@map("promotion_versions")
}

/// AuditorГ­a completa: quiГ©n, quГ©, cuГЎndo, estado anterior/nuevo y diff.
model PromotionAudit {
  id             String           @id @default(cuid())
  promotionId    String
  promotion      Promotion        @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId         String?
  accion         String // CREATED | UPDATED | STATUS_CHANGED | VERSIONED | ARCHIVED | ...
  estadoAnterior PromotionStatus?
  estadoNuevo    PromotionStatus?
  cambios        Json             @default("{}") // diff de campos modificados
  createdAt      DateTime         @default(now())

  @@index([promotionId, createdAt])
  @@index([companyId, createdAt])
  @@map("promotion_audits")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE 6: BUSINESS DATA DICTIONARY (DICCIONARIO UNIVERSAL DE DATOS)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Fuente OFICIAL de todas las variables de negocio que pueden usar reglas,
// promociones, membresГ­as, QR, etc. El catГЎlogo ESTГЃNDAR vive en cГіdigo
// (src/lib/dictionary/domain/catalog.ts); estas tablas persisten las variables
// CUSTOM/por-empresa registradas en runtime. Sin lГіgica de negocio. NingГєn flujo
// de la app las consume todavГ­a.

/// Estado de una variable del diccionario.
enum DictionaryVariableStatus {
  ACTIVE // disponible para usarse
  DEPRECATED // en desuso; se resuelve pero no deberГ­a usarse en variables nuevas
  DISABLED // desactivada; no se resuelve
}

/// DefiniciГіn centralizada de una variable de negocio. NUNCA depende de nombres
/// de columnas del ORM: `contextPath` apunta al Modelo Universal de Contexto.
model DataDictionaryVariable {
  id           String                   @id @default(cuid())
  companyId    String? // null = variable GLOBAL/estГЎndar; con valor = especГ­fica de empresa
  company      Company?                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key          String // nombre tГ©cnico, ej. "cliente.puntos"
  displayName  String // nombre visible
  description  String?
  semanticType String // tipo semГЎntico (TEXT|INTEGER|MONEY|PERCENT|вЂ¦) в†’ mapea a DataType del Rule Engine
  category     String // categorГ­a (Cliente, Empresa, SistemaвЂ¦)
  subcategory  String?
  ownerModule  String? // mГіdulo propietario
  source       String                   @default("CONTEXT") // CONTEXT | CALCULATED | CONSTANT | EXTERNAL
  contextPath  String? // ruta en el Context Model, ej. "cliente.puntos"
  format       String?
  unit         String?
  aliases      String[]                 @default([]) // nombres alternativos que resuelven a esta variable
  status       DictionaryVariableStatus @default(ACTIVE)
  version      Int                      @default(1)
  validation   Json                     @default("{}") // reglas de validaciГіn (rango, patrГіn, valoresвЂ¦)
  i18n         Json                     @default("{}") // { es: {name,description,help}, en: {...} }
  calculated   Json? // descriptor de variable calculada (kind + inputs); null si no lo es
  metadata     Json                     @default("{}")
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  versions DataDictionaryVariableVersion[]

  @@unique([companyId, key]) // Гєnica por empresa (y una global por key con companyId null)
  @@index([companyId, category])
  @@index([category])
  @@index([status])
  @@map("data_dictionary_variables")
}

/// InstantГЎnea de versiГіn de una variable (historial inmutable).
model DataDictionaryVariableVersion {
  id         String                 @id @default(cuid())
  variableId String
  variable   DataDictionaryVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json
  createdAt  DateTime               @default(now())

  @@unique([variableId, version])
  @@index([variableId])
  @@map("data_dictionary_variable_versions")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE A: MEMBERSHIP ENGINE UNIVERSAL
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Motor universal de membresГ­as: modela CUALQUIER modelo comercial (los 20 de la
// Membership Strategy Library) por CONFIGURACIГ“N, no por cГіdigo. Independiente de
// la industria y del modelo `Membership` (Car Wash) existente, que NO se toca.
// Reutiliza Rule/Action/Context/Dictionary/BEL para reglas de uso y automatizaciГіn.

/// Modelo comercial de la membresГ­a (los 20 de la biblioteca de estrategias).
enum MembershipPlanType {
  UNLIMITED
  CREDITS
  HYBRID
  TIER
  FAMILY
  FLEET
  CORPORATE
  SEASONAL
  PREMIUM
  MAINTENANCE
  PAY_PER_VISIT
  LOYALTY
  PREPAID
  VIP
  REWARDS
  TRIAL
  STUDENT
  DRIVER
  SUBSCRIPTION_BOX
  CUSTOM
}

/// Periodicidad de cobro/renovaciГіn.
enum MembershipPeriodicity {
  NONE
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  SEASONAL
}

/// Estado de una membresГ­a de un suscriptor concreto.
enum MembershipInstanceStatus {
  PENDING
  ACTIVE
  PAUSED
  SUSPENDED
  EXPIRED
  CANCELLED
}

/// DefiniciГіn (plantilla instanciada) de un plan de membresГ­a de una empresa.
/// Toda la configuraciГіn especГ­fica vive en `config` (JSON): servicios incluidos,
/// lГ­mites, beneficios, reglas de uso, renovaciГіn, segmentos, restricciones,
/// mГ©tricas y automatizaciones. Nunca columnas por caso.
model MembershipPlan {
  id           String                @id @default(cuid())
  companyId    String
  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  tipo         MembershipPlanType
  precio       Decimal               @db.Decimal(10, 2)
  moneda       String                @default("DOP")
  periodicidad MembershipPeriodicity @default(MONTHLY)
  duracionDias Int? // null = ligado a periodicidad
  creditos     Int? // para CREDITS/HYBRID (null = no aplica)
  ilimitado    Boolean               @default(false) // para UNLIMITED/tiers unlimited
  templateKey  String? // plantilla de industria de la que naciГі (ej. "carwash.unlimited")
  config       Json                  @default("{}") // configuraciГіn flexible (ver dominio)
  status       String                @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  version      Int                   @default(1)
  metadata     Json                  @default("{}")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  instances MembershipInstance[]

  @@index([companyId, tipo])
  @@index([companyId, status])
  @@map("membership_plans")
}

/// MembresГ­a de un suscriptor (cliente, familia, empresa/flotaвЂ¦). El suscriptor
/// se referencia de forma genГ©rica (`subscriberId`/`subscriberKind`) para no
/// acoplar el motor a una entidad concreta.
model MembershipInstance {
  id                String                   @id @default(cuid())
  companyId         String
  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId            String
  plan              MembershipPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriberId      String // ref. genГ©rica al titular
  subscriberKind    String                   @default("CLIENT") // CLIENT | COMPANY | USER
  status            MembershipInstanceStatus @default(PENDING)
  inicioEn          DateTime?
  finEn             DateTime?
  renuevaEn         DateTime?
  autoRenovar       Boolean                  @default(false)
  creditosRestantes Int?
  vehiculos         Json                     @default("[]") // family/fleet: lista de vehГ­culos
  config            Json                     @default("{}") // overrides/snapshot
  metadata          Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  usage MembershipUsage[]

  @@index([companyId, status])
  @@index([planId])
  @@index([subscriberId])
  @@map("membership_instances")
}

/// Registro de uso (Usage Tracking): cada consumo de un servicio/beneficio.
model MembershipUsage {
  id         String             @id @default(cuid())
  companyId  String // scalar (sin relaciГіn) para filtrar por empresa
  instanceId String
  instance   MembershipInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  servicio   String // ej. "lavado_exterior", "detailing"
  cantidad   Int                @default(1)
  vehiculo   String? // placa/id de vehГ­culo cuando aplica
  usadoEn    DateTime           @default(now())
  meta       Json               @default("{}")

  @@index([instanceId, usadoEn])
  @@index([companyId, usadoEn])
  @@map("membership_usage")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE C В· BENEFIT ENGINE (Benefits & Rewards Library)
// Un beneficio es una ENTIDAD independiente y editable que cualquier mГіdulo
// (membresГ­as, promociones, referidos, puntos, gamificaciГіn, campaГ±as,
// automatizaciones) puede seleccionar, modificar o crear. Todo lo especГ­fico
// vive en `config` (JSON): valor, servicio, reglas, restricciones,
// disponibilidad y mГіdulos donde puede usarse. NingГєn flujo existente lo
// consume todavГ­a.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Los 10 tipos base de beneficio (el detalle вЂ”% vs monto, servicio, etc.вЂ”
/// vive en `config`). CUSTOM habilita beneficios creados por la empresa.
enum BenefitType {
  SERVICE_FREE // servicio gratis (lavado, aspirado, ceraвЂ¦)
  DISCOUNT // descuento (% o monto fijo, segГєn config)
  UPGRADE // mejora de servicio (bГЎsicoв†’premium)
  PRODUCT // producto fГ­sico
  POINTS // puntos de lealtad
  CREDIT // crГ©dito/saldo interno (wallet)
  TIME // tiempo (mes gratis, visita extra, precio congelado)
  EXPERIENCE // experiencia (evento, servicio personalizado)
  ACCESS // acceso exclusivo (lГ­nea rГЎpida, ГЎrea VIP)
  CUSTOM // beneficio personalizado de la empresa
}

/// Estado de un beneficio entregado a un suscriptor (ciclo de canje).
enum BenefitGrantStatus {
  GRANTED // entregado, disponible para canjear
  REDEEMED // canjeado/utilizado
  EXPIRED // venciГі sin usarse
  REVOKED // revocado por la empresa
}

/// CatГЎlogo de beneficios de una empresa (plantilla instanciada o creado a
/// mano). Reutilizable por todos los mГіdulos. `costoReal` vs `valorPercibido`
/// permiten calcular rentabilidad/ROI.
model Benefit {
  id             String      @id @default(cuid())
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code           String? // ej. "CAR-001" cuando nace de una plantilla
  nombre         String
  descripcion    String?
  categoria      String // categorГ­a de la biblioteca (SERVICE, DISCOUNT, VIPвЂ¦)
  tipo           BenefitType
  valorPercibido Decimal?    @db.Decimal(10, 2) // lo que el cliente cree que vale
  costoReal      Decimal?    @db.Decimal(10, 2) // lo que le cuesta al negocio
  templateKey    String? // plantilla de industria de la que naciГі
  config         Json        @default("{}") // valor, servicio, reglas, restricciones, disponibilidad, mГіdulos
  status         String      @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  grants                  BenefitGrant[]
  // Benefit Transformation Engine (Fase E1.7). Relaciones inversas.
  transformationsAsSource BenefitTransformation[] @relation("TransformationSource")
  transformationsAsTarget BenefitTransformation[] @relation("TransformationTarget")

  @@index([companyId, status])
  @@index([companyId, categoria])
  @@index([companyId, tipo])
  @@map("benefits")
}

/// Beneficio entregado a un suscriptor desde un mГіdulo concreto. Es la fuente
/// de las mГ©tricas del Benefit Engine (entregados, utilizados, costo real, ROI).
model BenefitGrant {
  id             String             @id @default(cuid())
  companyId      String // scalar (sin relaciГіn) para filtrar por empresa
  benefitId      String
  benefit        Benefit            @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  subscriberId   String // ref. genГ©rica al titular (cliente/usuario/empresa)
  subscriberKind String             @default("CLIENT")
  sourceModule   String // membership | promotion | referral | points | gamification | campaign | automation
  status         BenefitGrantStatus @default(GRANTED)
  grantedAt      DateTime           @default(now())
  redeemedAt     DateTime?
  expiresAt      DateTime?
  meta           Json               @default("{}")

  @@index([companyId, status])
  @@index([benefitId, status])
  @@index([subscriberId])
  @@index([companyId, sourceModule])
  @@map("benefit_grants")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE E1.7 В· BENEFIT TRANSFORMATION ENGINE
// Motor universal de transformaciГіn de beneficios: upgrade, downgrade, exchange,
// replacement, customization, split, merge. Historial inmutable, resoluciГіn
// automГЎtica de fondeo (puntos, crГ©ditos, cupones, promociones, pago) y
// polГ­ticas configurables por empresa. Sin lГіgica de industria.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum TransformationType {
  UPGRADE // mejora (bГЎsico в†’ premium)
  DOWNGRADE // rebaja (premium в†’ bГЎsico)
  EXCHANGE // intercambio (A в†’ B + C)
  REPLACEMENT // reemplazo autorizado
  CUSTOMIZATION // personalizaciГіn antes de consumir
  SPLIT // dividir un beneficio en varios (arquitectura preparada)
  MERGE // combinar varios en uno (arquitectura preparada)
}

enum TransformationStatus {
  REQUESTED // cliente lo solicitГі
  RESOLVING // calculando mejor forma de fondear
  RESOLVED // resoluciГіn encontrada, esperando acciГіn
  PENDING_APPROVAL // requiere aprobaciГіn administrativa
  APPROVED // aprobado, pendiente de ejecuciГіn/pago
  PENDING_PAYMENT // esperando pago de diferencia
  EXECUTING // ejecutando la transformaciГіn
  COMPLETED // completada exitosamente
  REJECTED // rechazada por admin
  CANCELLED // cancelada por cliente
  FAILED // fallГі durante ejecuciГіn
}

/// Registro inmutable de una transformaciГіn de beneficio. Cada operaciГіn genera
/// un registro independiente: nunca se sobrescribe el beneficio original.
model BenefitTransformation {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriberId   String
  subscriberKind String               @default("CLIENT")
  type           TransformationType
  status         TransformationStatus @default(REQUESTED)

  // Beneficio origen
  sourceBenefitId String
  sourceBenefit   Benefit @relation("TransformationSource", fields: [sourceBenefitId], references: [id])
  sourceGrantId   String?

  // Beneficio destino (null hasta que se resuelva)
  targetBenefitId String?
  targetBenefit   Benefit? @relation("TransformationTarget", fields: [targetBenefitId], references: [id])
  targetGrantId   String?

  // EconomГ­a
  sourceValue      Decimal? @db.Decimal(10, 2)
  targetValue      Decimal? @db.Decimal(10, 2)
  differenceAmount Decimal? @db.Decimal(10, 2) // diferencia bruta
  resolvedAmount   Decimal? @db.Decimal(10, 2) // monto final tras aplicar fondeos

  // ResoluciГіn: detalle de quГ© fuentes se usaron (puntos, crГ©ditos, promosвЂ¦)
  resolution       Json      @default("{}")
  // PolГ­tica que autorizГі la transformaciГіn
  policyId         String?
  requiresApproval Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?
  rejectionReason  String?

  // Contexto
  sucursalId    String?
  requestedById String?
  config        Json    @default("{}")
  metadata      Json    @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([companyId, status])
  @@index([companyId, type])
  @@index([subscriberId])
  @@index([sourceBenefitId])
  @@index([targetBenefitId])
  @@map("benefit_transformations")
}

/// PolГ­tica de transformaciГіn configurable por empresa. Define quГ©
/// transformaciones estГЎn permitidas, con quГ© restricciones y mГ©todos de fondeo.
model TransformationPolicy {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  tipo        TransformationType
  activa      Boolean            @default(true)
  prioridad   Int                @default(0)
  config      Json               @default("{}") // TransformationPolicyConfig
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([companyId, tipo, activa])
  @@map("transformation_policies")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE D В· REFERRAL ENGINE (Referral Strategy Library)
// Motor universal de programas de recomendaciГіn 100% configurables. Reutiliza
// el Benefit Engine (Fase C) para las recompensas, sin duplicar lГіgica. Todo lo
// especГ­fico (reglas, recompensas, escalado, lГ­mites, condiciones, segmentos,
// estados, tipos de enlace, antifraude, mГ©tricas) vive en `config` (JSON).
// Coexiste con el sistema de referidos EN VIVO (Referido/ReferralEvent) sin
// tocarlo. NingГєn flujo existente consume estas tablas todavГ­a.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Los 10 modelos de programa de referidos del Documento Maestro 4.
enum ReferralModel {
  CLASSIC // ambos participan; negocios pequeГ±os
  REFERRER_ONLY // solo gana quien invita
  REFERRED_ONLY // solo gana el nuevo cliente (captaciГіn)
  BOTH // ambos ganan (el mГЎs usado)
  PROGRESSIVE // recompensa escalonada por cantidad de referidos
  AMBASSADOR // embajadores con beneficios permanentes
  INFLUENCER // alcance; no requiere compras frecuentes
  CORPORATE // una empresa recomienda a otra
  EMPLOYEE // empleados generan clientes
  TEAM // sucursales/equipos compiten
}

/// Estado de un participante (quien invita) dentro de un programa.
enum ReferralParticipantStatus {
  ACTIVE
  PAUSED
  BLOCKED
}

/// Programa de referidos configurable de una empresa. `type` fija el modelo;
/// el resto de la estrategia vive en `config`.
model ReferralProgram {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre      String
  objetivo    String? // captaciГіn, retenciГіn, alcance, corporativoвЂ¦
  type        ReferralModel
  templateKey String? // plantilla de industria de la que naciГі
  config      Json          @default("{}") // reglas, recompensas, escalado, lГ­mites, condiciones, segmentos, estados, enlaces, antifraude, mГ©tricas
  status      String        @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  participants ReferralParticipant[]
  referrals    ReferralReferral[]

  @@index([companyId, status])
  @@index([companyId, type])
  @@map("referral_programs")
}

/// Un participante inscrito en un programa (quien invita): su cГіdigo/enlace,
/// contadores y nivel de escalado. El titular se referencia de forma genГ©rica.
model ReferralParticipant {
  id             String                    @id @default(cuid())
  companyId      String
  programId      String
  program        ReferralProgram           @relation(fields: [programId], references: [id], onDelete: Cascade)
  referrerId     String // ref. genГ©rica (cliente/usuario/empresa/sucursal)
  referrerKind   String                    @default("CLIENT")
  code           String // cГіdigo Гєnico del participante dentro del programa
  status         ReferralParticipantStatus @default(ACTIVE)
  level          Int                       @default(0) // nivel de escalado alcanzado
  referralsCount Int                       @default(0) // referidos registrados
  convertedCount Int                       @default(0) // referidos que convirtieron
  metadata       Json                      @default("{}")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  referrals ReferralReferral[]

  @@unique([programId, code])
  @@index([companyId, programId])
  @@index([referrerId])
  @@map("referral_participants")
}

/// Un referido concreto y su recorrido por el flujo configurable de estados.
/// La recompensa se libera en el estado que la empresa decida (config.rewardState).
model ReferralReferral {
  id             String              @id @default(cuid())
  companyId      String
  programId      String
  program        ReferralProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  participantId  String
  participant    ReferralParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  referredId     String? // ref. genГ©rica al invitado (null hasta que se registra)
  referredKind   String              @default("CLIENT")
  state          String              @default("INVITED") // estado actual del flujo configurable
  history        Json                @default("[]") // [{state, at}] recorrido
  suspicious     Boolean             @default(false) // antifraude
  fraudReasons   Json                @default("[]") // cГіdigos de reglas disparadas
  rewardReleased Boolean             @default(false)
  rewardGrantId  String? // id del BenefitGrant liberado (Fase C)
  invitedAt      DateTime            @default(now())
  meta           Json                @default("{}")

  @@index([companyId, programId, state])
  @@index([participantId, state])
  @@index([referredId])
  @@map("referral_referrals")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE E1 В· AUTOMATION ENGINE (Automation Strategy Library)
// Motor UNIVERSAL de automatizaciones. Una automatizaciГіn nunca contiene lГіgica
// fija: se compone de piezas reutilizables (trigger + condiciones + acciones +
// esperas + variables + eventos). Reutiliza OBLIGATORIAMENTE el Rule Engine
// (decisiones) y el Action Engine (acciones); no ejecuta nada por su cuenta.
// Toda la estrategia vive en `config` (JSON). Multi-tenant por companyId.
// NingГєn flujo de la app consume estas tablas todavГ­a.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Estado de una ejecuciГіn (run) de automatizaciГіn.
enum AutomationRunStatus {
  RUNNING
  WAITING // pausada en una espera (se reanuda luego)
  SUCCESS
  FAILED
  SKIPPED // no aplicaba (horario/lГ­mite/condiciГіn inicial)
}

/// Una automatizaciГіn configurable de una empresa. Trigger + pasos (condiciones
/// + acciones + esperas) + lГ­mites/horarios/canales viven en `config`. Puede
/// nacer de una plantilla (`templateKey`) y encadenar otras automatizaciones.
model Automation {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  objetivo     String? // captaciГіn, onboarding, frecuencia, recuperaciГіnвЂ¦
  templateKey  String? // plantilla universal de la que naciГі
  /// Tipo de disparador (EVENT | SCHEDULE | SEGMENT_ENTER | DATE | MANUALвЂ¦).
  triggerType  String
  /// Para EVENT: tipo de evento que la dispara (ej. "cliente.visita").
  triggerEvent String?
  config       Json     @default("{}") // trigger, pasos, variables, lГ­mites, horarios, dГ­as, canales, encadenado, prioridad
  status       String   @default("DRAFT") // DRAFT | PUBLISHED | PAUSED | ARCHIVED
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  runs AutomationRun[]

  @@index([companyId, status])
  @@index([companyId, triggerType])
  @@index([companyId, triggerEvent])
  @@map("automations")
}

/// Registro/auditorГ­a de una ejecuciГіn: hora, trigger, reglas evaluadas,
/// acciones ejecutadas, resultado, errores y tiempo. Toda ejecuciГіn auditable.
model AutomationRun {
  id             String              @id @default(cuid())
  companyId      String
  automationId   String
  automation     Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status         AutomationRunStatus @default(RUNNING)
  /// Sujeto impactado (cliente/usuario/empresa), ref. genГ©rica.
  subjectId      String?
  subjectKind    String?
  triggeredBy    String? // trigger/evento que la originГі
  rulesEvaluated Json                @default("[]") // [{expr, passed}]
  actionsRun     Json                @default("[]") // [{type, ok, detail}]
  result         Json                @default("{}")
  error          String?
  durationMs     Int?
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  meta           Json                @default("{}")

  @@index([companyId, automationId, status])
  @@index([companyId, startedAt])
  @@index([subjectId])
  @@map("automation_runs")
}

/// Bus de eventos: toda acciГіn importante genera un evento que otras
/// automatizaciones pueden consumir (encadenado). `processed` evita reprocesar.
model AutomationEvent {
  id          String   @id @default(cuid())
  companyId   String
  type        String // ej. "cliente.registrado", "cliente.visita", "cliente.subio_nivel"
  subjectId   String?
  subjectKind String?  @default("CLIENT")
  payload     Json     @default("{}")
  source      String? // automationId/mГіdulo que lo emitiГі
  processed   Boolean  @default(false)
  occurredAt  DateTime @default(now())

  @@index([companyId, type, processed])
  @@index([companyId, occurredAt])
  @@index([subjectId])
  @@map("automation_events")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// FASE E4 В· TRANSACTION & RECEIPT ENGINE
// Toda operaciГіn (redenciГіn de membresГ­a, promociГіn, beneficio, recompensa,
// cupГіn, puntos, referido, venta futuraвЂ¦) genera una TRANSACCIГ“N oficial con
// ID Гєnico (TX-YYYYMMDD-NNNNNN), estados con historial de transiciones,
// auditorГ­a completa y comprobante reimprimible. Universal: sin lГіgica de
// industria (la especificidad vive en snapshot/config JSON y plantillas).
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum TransactionTipo {
  MEMBERSHIP_REDEMPTION // uso de membresГ­a (visita)
  PROMOTION_USE
  BENEFIT_USE
  REWARD_REDEMPTION
  COUPON_USE
  POINTS_SPEND
  REFERRAL
  SALE // ventas futuras
  PURCHASE // compras futuras
  OTHER
}

enum TransactionEstado {
  PENDING
  VALIDATING
  APPROVED
  APPLIED
  CANCELLED
  REVERTED
  EXPIRED
  ERROR
}

model Transaction {
  id           String            @id @default(cuid())
  /// ID oficial Гєnico e irrepetible: TX-YYYYMMDD-NNNNNN. Se imprime en el
  /// ticket, se codifica en el QR de la transacciГіn y sirve para consultas.
  codigo       String            @unique
  /// NГєmero de ticket secuencial por empresa (TCK-000123).
  ticketNumero String
  tipo         TransactionTipo
  estado       TransactionEstado @default(PENDING)

  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sucursalId String?
  sucursal   Sucursal? @relation(fields: [sucursalId], references: [id])
  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id])
  empleadoId String?
  empleado   User?     @relation("TransactionEmpleado", fields: [empleadoId], references: [id])
  /// Caja/terminal (texto libre; con gestiГіn de cajas se usa cajaSesionId).
  caja         String?
  /// SesiГіn de caja en la que se registrГі el cobro (POS).
  cajaSesionId String?
  cajaSesion   CajaSesion?      @relation(fields: [cajaSesionId], references: [id])
  /// Monto cobrado y forma de cobro (para arqueo y reportes de ventas).
  monto        Decimal?         @db.Decimal(10, 2)
  metodoCobro  MetodoCobroTipo?

  membershipId   String?
  membership     Membership? @relation(fields: [membershipId], references: [id])
  visitId        String?     @unique
  visit          Visit?      @relation(fields: [visitId], references: [id])
  /// QR de un solo uso que se consumiГі para crear esta transacciГіn: permite
  /// que re-escanear un QR usado muestre el historial completo de la operaciГіn.
  qrTokenUsadoId String?     @unique
  qrTokenUsado   QrToken?    @relation("TransactionQrUsado", fields: [qrTokenUsadoId], references: [id])

  /// Etiquetas congeladas al momento de la operaciГіn (cliente, vehГ­culo,
  /// servicio, promociГіn, beneficio, membresГ­a, plan, empleado, sucursalвЂ¦):
  /// el historial no cambia aunque cambien los datos maestros.
  snapshot     Json    @default("{}")
  /// AuditorГ­a tГ©cnica: ip, userAgent, dispositivo, navegador.
  auditoria    Json    @default("{}")
  /// Resultado legible u observaciones del operador.
  resultado    String?
  errorDetalle String?
  /// DuraciГіn de la operaciГіn (ms) para mГ©tricas de tiempo de atenciГіn.
  executionMs  Int?

  createdAt   DateTime  @default(now())
  appliedAt   DateTime?
  cancelledAt DateTime?
  revertedAt  DateTime?

  transiciones TransactionTransicion[]
  impresiones  ReceiptImpresion[]

  @@index([companyId, estado])
  @@index([companyId, createdAt])
  @@index([clienteId, createdAt])
  @@index([empleadoId])
  @@index([cajaSesionId])
  @@map("transactions")
}

/// Historial inmutable de cambios de estado de una transacciГіn.
model TransactionTransicion {
  id            String             @id @default(cuid())
  transactionId String
  transaction   Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  desde         TransactionEstado?
  hacia         TransactionEstado
  motivo        String?
  userId        String?
  user          User?              @relation(fields: [userId], references: [id])
  createdAt     DateTime           @default(now())

  @@index([transactionId, createdAt])
  @@map("transaction_transitions")
}

/// Contadores atГіmicos para IDs secuenciales (TX por dГ­a, ticket por empresa).
/// id = scope, ej. "TX:20260711" o "TICKET:companyId". Se incrementa con
/// INSERT ... ON CONFLICT DO UPDATE ... RETURNING (una sola sentencia atГіmica).
model TransactionCounter {
  id  String @id
  seq Int    @default(0)

  @@map("transaction_counters")
}

/// Cada impresiГіn/reimpresiГіn de comprobante queda auditada.
model ReceiptImpresion {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  empleadoId    String?
  empleado      User?       @relation(fields: [empleadoId], references: [id])
  /// false = impresiГіn original; true = COPIA.
  esCopia       Boolean     @default(false)
  /// NВє de impresiГіn de esta transacciГіn (1 = original, 2+ = copias).
  numero        Int
  motivo        String?
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@map("receipt_prints")
}

/// Plantilla de comprobante por empresa (Receipt Engine): personalizaciГіn de
/// encabezado, pie, bloques, campos opcionales y ancho de papel SIN tocar
/// cГіdigo. `config` sigue el contrato ReceiptTemplateConfig de src/lib/receipts.
model ReceiptTemplate {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("receipt_templates")
}

// ---------------------------------------------------------------------------
// Growth Engine вЂ” CampaГ±as de InvitaciГіn ("Invita y Gana")
// ---------------------------------------------------------------------------

enum CampanaInvitacionEstado {
  BORRADOR
  ACTIVA
  PAUSADA
  FINALIZADA
}

enum InvitacionEventoTipo {
  COMPARTIDA
  ENLACE_ABIERTO
  LANDING_VISTA
  REGISTRO_INICIADO
  REGISTRO_COMPLETADO
  PREMIO_RECLAMADO
  MEMBRESIA_ADQUIRIDA
  PRIMER_CANJE
  CONVERSION_FINAL
}

// CampaГ±a "Invita y Gana" (uno de los 3 modelos "campaГ±a"; ver Campana arriba).
model CampanaInvitacion {
  id             String                   @id @default(cuid())
  companyId      String
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug           String                   @unique
  nombre         String
  titulo         String
  descripcion    String                   @db.Text
  textoLanding   String?                  @db.Text
  imagenUrl      String?
  bannerUrl      String?
  metaRegistros  Int
  beneficioInvitante Json
  beneficioInvitado  Json
  fechaInicio    DateTime
  fechaFin       DateTime
  maxPremios     Int?
  premiosOtorgados Int                    @default(0)
  estado         CampanaInvitacionEstado  @default(BORRADOR)
  colorPrimario  String?
  colorSecundario String?
  orden          Int                      @default(0)
  // Si es true, el enlace muestra la pГЎgina de presentaciГіn (banner/hero) antes
  // del formulario. Si es false (por defecto), lleva directo al registro.
  usarBanner     Boolean                  @default(false)
  // Textos editables del mГіdulo "Invita y Gana" del cliente (subtГ­tulo,
  // etiquetas, mensaje de compartir, tГ­tulos, nombres de estadГ­sticas, etc.).
  // Ausente = se usan los textos por defecto (ver src/lib/invitaContenido.ts).
  contenido      Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  progresos      InvitacionProgreso[]
  eventos        InvitacionEvento[]
  referidos      Referido[]

  @@index([companyId, estado])
  @@index([estado, fechaFin])
  @@map("campanas_invitacion")
}

model InvitacionProgreso {
  id                    String             @id @default(cuid())
  campanaId             String
  campana               CampanaInvitacion  @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  clienteId             String
  cliente               Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  companyId             String
  registrosCompletados  Int                @default(0)
  metaAlcanzada         Boolean            @default(false)
  premioReclamado       Boolean            @default(false)
  benefitGrantId        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([campanaId, clienteId])
  @@index([clienteId])
  @@map("invitacion_progresos")
}

model InvitacionEvento {
  id          String                  @id @default(cuid())
  campanaId   String
  campana     CampanaInvitacion       @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  clienteId   String?
  cliente     Cliente?                @relation(fields: [clienteId], references: [id])
  companyId   String
  tipo        InvitacionEventoTipo
  canal       String?
  dispositivo String?
  ipHash      String?
  meta        Json                    @default("{}")
  createdAt   DateTime                @default(now())

  @@index([campanaId, tipo])
  @@index([campanaId, clienteId])
  @@map("invitacion_eventos")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Engagement Engine В· Fase 2 вЂ” Motor de CampaГ±as de marketing.
// CampaГ±as que aparecen VIVAS en el Home del cliente (banner + contador +
// CTA), con ventana de fechas y, para Happy Hour / fin de semana, ventana
// horaria y dГ­as de la semana. Un mismo motor para cualquier tipo de negocio.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum MarketingCampaignTipo {
  FLASH_SALE      // oferta relГЎmpago con contador
  OFERTA_DIA      // cambia cada dГ­a
  FIN_DE_SEMANA   // solo viernes a domingo
  HAPPY_HOUR      // ventana horaria diaria (p. ej. 2pmвЂ“4pm)
  PRIMERA_COMPRA  // solo quien aГєn no ha comprado
  BIENVENIDA      // al registrarse
  REGRESO         // sin visitar hace +30 dГ­as
  CUMPLEANOS      // cupГіn de cumpleaГ±os
  POR_VENCER      // recordatorio de beneficio por vencer
  PERSONALIZADA   // genГ©rica
}

enum MarketingCampaignEstado {
  BORRADOR
  ACTIVA
  PAUSADA
  FINALIZADA
}

// Banner vivo del Home (uno de los 3 modelos "campaГ±a"; ver Campana arriba).
model MarketingCampaign {
  id          String                  @id @default(cuid())
  companyId   String
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipo        MarketingCampaignTipo   @default(FLASH_SALE)
  estado      MarketingCampaignEstado @default(BORRADOR)

  titulo          String
  descripcion     String  @db.Text
  imagenUrl       String?
  bannerUrl       String?
  ctaTexto        String? // "Aprovecha ahora"
  ctaHref         String? // ruta interna, p. ej. /cliente/promociones
  colorPrimario   String?
  colorSecundario String?

  fechaInicio DateTime
  fechaFin    DateTime

  // Happy Hour / fin de semana: ventana horaria (minutos desde medianoche,
  // hora local RD) y dГ­as activos (0=Dom вЂ¦ 6=SГЎb; vacГ­o = todos los dГ­as).
  horaInicioMin Int?
  horaFinMin    Int?
  diasSemana    Int[]

  prioridad     Int     @default(0)
  destacada     Boolean @default(false)
  // Urgencia/stock: cupones disponibles (null = ilimitado).
  maxReclamos   Int?
  reclamosCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, estado, fechaInicio, fechaFin])
  @@index([estado, fechaFin])
  @@map("marketing_campaigns")
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Engagement Engine В· Fase 6B вЂ” Ruleta de premios (gasta puntos ganados).
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum RuletaPremioTipo {
  PROMOCION // entrega una promociГіn como beneficio (ProductoCompra + QR)
  NADA      // segmento "sigue participando" (no otorga premio)
}

model RuletaPremio {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre       String
  tipo         RuletaPremioTipo @default(PROMOCION)
  promocionId  String?
  promocion    Promocion?       @relation(fields: [promocionId], references: [id])
  probabilidad Int              @default(1) // peso relativo (mayor = mГЎs probable)
  color        String?
  activo       Boolean          @default(true)
  orden        Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  jugadas RuletaJugada[]

  @@index([companyId, activo])
  @@map("ruleta_premios")
}

model RuletaJugada {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId        String
  cliente          Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  costoPuntos      Int
  premioId         String?
  premio           RuletaPremio? @relation(fields: [premioId], references: [id])
  premioNombre     String
  gano             Boolean  @default(false)
  productoCompraId String?
  createdAt        DateTime @default(now())

  @@index([companyId, clienteId])
  @@index([clienteId, createdAt])
  @@map("ruleta_jugadas")
}
