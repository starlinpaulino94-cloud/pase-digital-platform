# ============================================================
# MEMBEGO PLATFORM — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a Git
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS (Supabase PostgreSQL)
# Obtén estas URLs desde: Supabase → Settings → Database → Connection string
# ------------------------------------------------------------

# Transaction pooler — usa pgBouncer, ideal para serverless (Prisma en prod)
# IMPORTANTE: incluye SIEMPRE `connection_limit` y `pool_timeout`. Sin
# connection_limit, cada instancia serverless abre num_cpus*2+1 conexiones;
# con varias instancias calientes se agota el pool de pgBouncer y aparecen
# errores intermitentes (P2024) en toda la app. En Vercel usa connection_limit=1.
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20
DATABASE_URL=""

# Direct connection — sin pgBouncer, solo para migraciones (prisma migrate)
# Formato: postgresql://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL=""

# ------------------------------------------------------------
# SUPABASE AUTH
# Obtén estas claves desde: Supabase → Settings → API
# ------------------------------------------------------------

# URL del proyecto Supabase (pública, va al frontend)
NEXT_PUBLIC_SUPABASE_URL=""

# Clave anon/pública (safe para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Clave service_role (PRIVADA — solo backend/server actions)
SUPABASE_SERVICE_ROLE_KEY=""

# ------------------------------------------------------------
# DOMINIO Y MARCA (MembeGo)
# ------------------------------------------------------------

# URL base oficial de producción. Se usa para metadata/OG/canonical, sitemap,
# enlaces de referido y correos. Sin barra final.
NEXT_PUBLIC_APP_URL="https://membego.com"

# ------------------------------------------------------------
# CORREO (Resend)
# ------------------------------------------------------------

# Remitente de los correos del sistema. El dominio membego.com debe estar
# verificado en Resend (DNS) para que el envío funcione.
EMAIL_FROM="MembeGo <no-reply@membego.com>"

# API key de Resend (privada). Sin ella, el envío de correo queda deshabilitado.
RESEND_API_KEY=""

# ------------------------------------------------------------
# ENDPOINTS DE ARRANQUE / OPERACIÓN (sensibles)
# Usados por /api/bootstrap-superadmin y /api/admin-reset-password para crear el
# primer SUPERADMIN o reparar contraseñas. Apagados por defecto.
# ------------------------------------------------------------

# Habilita los endpoints de bootstrap. Déjalo SIN definir (o en "false") en
# operación normal. Ponlo en "true" solo mientras haces el arranque inicial y
# vuélvelo a apagar al terminar. Sin esto, los endpoints responden 404.
BOOTSTRAP_ENABLED=""

# Secreto para autorizar los endpoints de bootstrap (header x-bootstrap-secret).
# Debe tener al menos 24 caracteres. Genera uno aleatorio y no lo reutilices.
BOOTSTRAP_SECRET=""

# ------------------------------------------------------------
# SENTRY (monitoreo de errores) — opcional
# Si no configuras el DSN, Sentry queda inactivo (la app funciona igual).
# Obtén el DSN en: Sentry → Settings → Projects → membego → Client Keys (DSN)
# ------------------------------------------------------------

# DSN del proyecto. Va tanto al servidor como al cliente (usa el mismo valor).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Entorno reportado a Sentry (production / staging / development).
# Si se omite, se usa VERCEL_ENV y si no 'development'.
SENTRY_ENVIRONMENT=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT=""

# Release para asociar errores a una versión (opcional; por defecto el SHA de git).
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""

# Token para subir source maps en el build (privado). Solo necesario en CI/deploy.
# Sentry → Settings → Auth Tokens.
SENTRY_AUTH_TOKEN=""

# F4.7 · Automatizaciones: secreto para el endpoint /api/cron/automatizaciones
# (llamar con Authorization: Bearer $CRON_SECRET desde un cron diario)
CRON_SECRET=
